# Zabir Boutiques v7.0 — Environment Variables
#
# Two categories:
#   1. Build-time variables (CF_*) — used by `npm run build:snapshots`
#      to read D1 from a read-only token at build time. These run in
#      Node, not in the Worker.
#   2. Runtime secrets — set per-environment via `wrangler secret put`.
#      Never commit real values; only the example placeholders below.
#
# Required runtime secrets (deploy WILL fail without these):
#   SESSION_SECRET                HMAC key for sessions + CSRF (>= 32 bytes)
#   PASSWORD_PEPPER               PBKDF2 password pepper (>= 32 bytes)
#   TINIFY_API_KEY                Image compression
#   UDDOKTAPAY_API_KEY            Payment gateway
#   UDDOKTAPAY_BASE_URL           https://sandbox.uddoktapay.com (or prod)
#   FRAUDBD_API_KEY               Fraud scoring
#   DEEPSEEK_API_KEY              AI fallback
#   OPENAI_API_KEY                OpenAI-compatible endpoint (optional)
#   TURNSTILE_SECRET_KEY          Bot defense (optional in dev)
#   API_KEY_PEPPER                HMAC pepper for external API keys
#   AUDIT_LEDGER_SECRET           HMAC key for audit log chain
#   BACKUP_ENCRYPTION_KEY         AES-256-GCM key for D1 backups (32+ bytes)
#   RESEND_API_KEY                Transactional email
#   RESEND_FROM_EMAIL             Sender identity (default: orders@zabirboutiques.com)
#   AI_FALLBACK_KEY               DeepSeek API key (alternate name)
#   AI_FALLBACK_URL               DeepSeek endpoint
#   CF_API_TOKEN                  Cloudflare API token (cache purges)
#   CF_ZONE_ID                    Cloudflare zone ID (cache purges)

# Build-time D1 snapshot access (Cloudflare Pages build only)
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_D1_READ_TOKEN=
