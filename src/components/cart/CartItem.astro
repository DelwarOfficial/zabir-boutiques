---
interface Props {
  variantId: string;
  imageUrl: string;
  title: string;
  variantLabel: string;
  unitPricePaisa: number;
  quantity: number;
  availableQuantity: number;
}

const { variantId, imageUrl, title, variantLabel, unitPricePaisa, quantity, availableQuantity } = Astro.props;
---

<div class="shell-card flex gap-4 p-4">
  <div class="aspect-square h-24 w-24 shrink-0 overflow-hidden rounded-xl bg-[var(--surface-soft)]">
    <img src={imageUrl} alt={title} width="96" height="96" class="h-full w-full object-cover" loading="lazy" />
  </div>
  <div class="flex flex-1 flex-col justify-between min-w-0">
    <div>
      <p class="font-bold text-sm line-clamp-2">{title}</p>
      <p class="text-xs font-semibold text-[var(--muted)] mt-0.5">{variantLabel}</p>
      <p class="mt-1 font-extrabold tabular text-sm">৳{(unitPricePaisa * quantity / 100).toLocaleString('en-BD', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}</p>
    </div>
    <div class="flex items-center gap-2">
      <button
        type="button"
        data-action="decrease-qty"
        data-variant-id={variantId}
        class="press tap-44 grid place-items-center h-8 w-8 rounded-lg border border-[var(--line)] hover:bg-[var(--surface-soft)]"
        title="Decrease quantity"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 12H4"/></svg>
      </button>
      <span class="w-8 text-center text-sm font-extrabold tabular">{quantity}</span>
      <button
        type="button"
        data-action="increase-qty"
        data-variant-id={variantId}
        disabled={quantity >= availableQuantity}
        class="press tap-44 grid place-items-center h-8 w-8 rounded-lg border border-[var(--line)] hover:bg-[var(--surface-soft)] disabled:opacity-40 disabled:cursor-not-allowed"
        title="Increase quantity"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
      </button>
    </div>
  </div>
  <button
    type="button"
    data-action="remove-item"
    data-variant-id={variantId}
    class="press tap-44 h-8 w-8 rounded-lg hover:bg-[var(--danger-storefront)]/10 text-[var(--danger-storefront)] shrink-0"
    title="Remove item"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
  </button>
</div>
