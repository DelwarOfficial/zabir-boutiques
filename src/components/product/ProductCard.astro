---
import { AddToCartButton } from "@/islands/AddToCartButton";
import { formatPaisa } from "@/lib/money";

const { product } = Astro.props;
---

<article class="group">
  <a href={`/products/${product.slug}`} class="block overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-[var(--line)] transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
    <div class="aspect-[4/5] overflow-hidden bg-[var(--surface-soft)]">
      <img
        src={product.imageUrl}
        alt={product.title}
        width="512"
        height="512"
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
    </div>
    <div class="p-4">
      <h3 class="line-clamp-2 text-sm font-semibold leading-snug text-zinc-800">{product.title}</h3>
      <div class="mt-2 flex items-center justify-between">
        <p class="text-base font-bold text-[var(--ink)]">{formatPaisa(product.pricePaisa)}</p>
        <p class="text-xs text-[var(--muted)]">{product.variantLabel}</p>
      </div>
    </div>
  </a>
  <div class="mt-2 px-1">
    <AddToCartButton
      client:idle
      productId={product.id}
      variantId={product.variantId}
      title={product.title}
      imageUrl={product.imageUrl}
      variantLabel={product.variantLabel}
      unitPricePaisa={product.pricePaisa}
      availableQuantity={product.availableQuantity}
    />
  </div>
</article>
