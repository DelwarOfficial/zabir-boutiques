---
import { AddToCartButton } from "@/islands/AddToCartButton";
import ProductImage from "@/components/product/ProductImage.astro";
import StockBadge from "@/components/product/StockBadge.astro";
import PriceDisplay from "@/components/product/PriceDisplay.astro";

const siteOrigin = Astro.site?.origin;

interface Props {
  product: any;
  isIsland?: boolean;
}

const { product, isIsland = false } = Astro.props;
---

<article class="group shine-card press fade-up">
  <a
    href={`/products/${product.slug}`}
    class="block"
    aria-label={`${product.title}`}
  >
    <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface-soft)]">
      <ProductImage
        imageUrl={product.imageUrl}
        alt={product.title}
        layout="card"
        siteOrigin={siteOrigin}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-500 will-change-transform group-hover:scale-105"
      />
      <!-- soft gradient overlay for legibility of corner chips -->
      <div class="pointer-events-none absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-black/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" aria-hidden="true"></div>

      <StockBadge availableQuantity={product.availableQuantity} class="absolute left-2 top-2" />
    </div>

    <div class="p-3 sm:p-4">
      <h3 class="line-clamp-2 text-[13px] sm:text-sm font-semibold leading-snug text-[var(--ink)] min-h-[2.5rem]">{product.title}</h3>
      <div class="mt-1.5 flex items-center justify-between gap-2">
        <PriceDisplay pricePaisa={product.pricePaisa} size="sm" />
        <p class="text-[10px] sm:text-xs text-[var(--muted)] truncate max-w-[55%]">{product.variantLabel}</p>
      </div>
    </div>
  </a>

  <div class="px-3 sm:px-4 pb-3 sm:pb-4">
    {isIsland ? (
      <AddToCartButton
        client:idle
        productId={product.id}
        variantId={product.variantId}
        title={product.title}
        imageUrl={product.imageUrl}
        variantLabel={product.variantLabel}
        unitPricePaisa={product.pricePaisa}
        availableQuantity={product.availableQuantity}
      />
    ) : (
      <button
        type="button"
        onclick={`window.addItemToLocalCart && window.addItemToLocalCart({
          productId: '${product.id}',
          variantId: '${product.variantId}',
          title: '${product.title.replace(/'/g, "\\'")}',
          imageUrl: '${product.imageUrl}',
          variantLabel: '${product.variantLabel}',
          unitPricePaisa: ${product.pricePaisa},
          quantity: 1,
          availableQuantity: ${product.availableQuantity}
        })`}
        disabled={product.availableQuantity <= 0}
        class="press tap-44 flex h-11 w-full items-center justify-center gap-1.5 rounded-xl text-sm font-semibold transition-all duration-200 border border-[var(--border-storefront)] bg-[var(--surface-storefront)] text-[var(--ink-storefront)] hover:border-[var(--brand-storefront)] hover:text-[var(--brand-storefront)] hover:bg-[var(--brand-storefront-light)] disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer"
      >
        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        {product.availableQuantity <= 0 ? 'Out of stock' : 'Add to cart'}
      </button>
    )}
  </div>
</article>
