---
import Select from "../primitives/Select.astro";
import Input from "../primitives/Input.astro";

interface Props {
  class?: string;
  error?: string;
}

const { class: className = '', error } = Astro.props;

const zones = [
  { value: "inside_dhaka", label: "Inside Dhaka (৳70)" },
  { value: "outside_dhaka", label: "Outside Dhaka (৳130)" }
];
---

<div class={`space-y-4 ${className}`}>
  <Select
    label="Delivery Zone"
    name="shipping_zone"
    required
    options={zones}
    placeholder="Select your area"
  />

  <div class="space-y-1.5">
    <label for="address" class="block text-xs font-semibold text-[var(--ink-storefront-secondary)] uppercase tracking-wider">
      Detailed Home Address <span class="text-[var(--danger-storefront)]">*</span>
    </label>
    <textarea
      id="address"
      name="address"
      required
      rows="3"
      placeholder="House number, road number, area name, city..."
      class={`w-full px-4 py-3 text-sm border rounded-xl bg-[var(--surface-storefront)] text-[var(--ink-storefront)] outline-none transition-all resize-none ${
        error
          ? 'border-[var(--danger-storefront)] focus:border-[var(--danger-storefront)]'
          : 'border-[var(--border-storefront)] focus:border-[var(--brand-storefront)] focus:ring-3 focus:ring-[var(--brand-storefront-glow)]'
      }`}
    ></textarea>
  </div>

  <Input
    label="Landmark (Optional)"
    name="landmark"
    placeholder="e.g. near Wari Aarong, AK Famous Tower"
  />
</div>
