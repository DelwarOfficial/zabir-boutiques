---
export type SpinnerSize = 'sm' | 'md' | 'lg';

interface Props {
  size?: SpinnerSize;
  class?: string;
  variant?: 'inline' | 'block';
}

const {
  size = 'md',
  class: className = '',
  variant = 'inline'
} = Astro.props;

const sizes: Record<SpinnerSize, string> = {
  sm: 'h-4 w-4 stroke-[3]',
  md: 'h-6 w-6 stroke-[2.5]',
  lg: 'h-8 w-8 stroke-[2]',
};

const displayClass = variant === 'block' ? 'block mx-auto' : 'inline-block';
---

<svg
  class={`animate-spin ${sizes[size]} ${displayClass} ${className}`}
  fill="none"
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
  role="status"
  aria-label="Loading"
  style="animation-duration: 0.8s;"
>
  <circle
    class="opacity-25"
    cx="12"
    cy="12"
    r="10"
    stroke="currentColor"
  ></circle>
  <path
    class="opacity-75"
    fill="currentColor"
    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
  ></path>
</svg>

<style>
  @media (prefers-reduced-motion: reduce) {
    svg {
      animation: none !important;
    }
  }
</style>
