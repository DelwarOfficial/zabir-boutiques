---
interface Props {
  id: string;
  title: string;
  class?: string;
}

const { id, title, class: className = '' } = Astro.props;
---

<dialog
  id={id}
  class={`backdrop:bg-black/40 backdrop:backdrop-blur-sm rounded-3xl bg-[var(--surface-storefront)] border border-[var(--border-storefront)] p-6 shadow-2xl max-w-lg w-[calc(100%-2rem)] max-h-[85vh] overflow-y-auto outline-none ${className}`}
>
  <div class="flex items-center justify-between border-b border-[var(--border-storefront)] pb-4 mb-4">
    <h3 class="text-lg font-bold text-[var(--ink-storefront)]">{title}</h3>
    <button
      type="button"
      data-close-dialog={id}
      class="tap-44 p-1.5 rounded-full hover:bg-[var(--surface-storefront-soft)] text-[var(--muted)] hover:text-[var(--ink-storefront)] transition"
      aria-label="Close modal"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <div class="text-sm leading-relaxed text-[var(--ink-storefront-secondary)]">
    <slot />
  </div>
  <div class="mt-6 flex justify-end gap-3">
    <slot name="footer" />
  </div>
</dialog>

<script is:inline define:vars={{ id }}>
  (function() {
    const dialog = document.getElementById(id);
    if (!dialog) return;

    // Attach click listeners to close buttons
    const closeBtns = dialog.querySelectorAll(`[data-close-dialog="${id}"]`);
    closeBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        dialog.close();
      });
    });

    // Close on clicking the backdrop (outside dialog boundaries)
    dialog.addEventListener('click', function(e) {
      const rect = dialog.getBoundingClientRect();
      const clickInDialog = (
        e.clientX >= rect.left &&
        e.clientX <= rect.right &&
        e.clientY >= rect.top &&
        e.clientY <= rect.bottom
      );
      if (!clickInDialog) {
        dialog.close();
      }
    });
  })();
</script>

<style>
  dialog::backdrop {
    animation: fade-in 180ms ease both;
  }
  dialog[open] {
    animation: pop 220ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }
</style>
