---
interface Props {
  id: string;
  title: string;
  message: string;
  confirmLabel?: string;
  cancelLabel?: string;
  confirmHref: string;
  variant?: 'danger' | 'primary';
  open?: boolean;
}

const { id, title, message, confirmLabel = 'Confirm', cancelLabel = 'Cancel', confirmHref, variant = 'danger', open = false } = Astro.props;
const iconColor = variant === 'danger' ? 'bg-red-100 text-red-600' : 'bg-brand-light text-brand';
---

<div id={id}
  class={`fixed inset-0 z-50 flex items-center justify-center ${open ? '' : 'hidden'}`}
  role="dialog" aria-modal="true" aria-labelledby={`${id}-title`}>
  <div class="absolute inset-0 bg-overlay" data-dismiss="true" />
  <div class="relative bg-surface rounded-xl shadow-lg p-6 max-w-sm w-full mx-4 fade-up">
    <div class="text-center">
      <div class={`w-12 h-12 mx-auto mb-4 rounded-full ${iconColor} flex items-center justify-center`}>
        {variant === 'danger' ? (
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01M3.07 12a9 9 0 1117.86 0A9 9 0 013.07 12z"/></svg>
        ) : (
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        )}
      </div>
      <h3 id={`${id}-title`} class="text-lg font-semibold text-ink m-0 mb-2">{title}</h3>
      <p class="text-sm text-ink-secondary m-0 mb-6">{message}</p>
      <div class="flex gap-3 justify-center">
        <button type="button" data-dismiss="true"
          class="px-4 py-2 text-sm font-semibold rounded-lg border border-line bg-surface text-ink hover:bg-surface-soft transition-all cursor-pointer">
          {cancelLabel}
        </button>
        <a href={confirmHref}
          class={`px-4 py-2 text-sm font-semibold rounded-lg text-white no-underline transition-all inline-flex items-center ${variant === 'danger' ? 'bg-danger hover:opacity-90' : 'bg-brand hover:opacity-90'}`}>
          {confirmLabel}
        </a>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const dialog = document.getElementById('{id}');
    if (!dialog) return;
    function hide() { dialog.classList.add('hidden'); }
    dialog.querySelectorAll('[data-dismiss]').forEach(el => el.addEventListener('click', hide));
  })();
</script>
