---
type SkeletonType = 'table' | 'card' | 'text';

interface Props {
  type?: SkeletonType;
  lines?: number;
}

const { type = 'text', lines = 4 } = Astro.props;
---

{
  type === 'table' && (
    <div class="space-y-3 p-4">
      <div class="flex gap-4">
        <div class="h-4 bg-surface-soft rounded skeleton w-1/4" />
        <div class="h-4 bg-surface-soft rounded skeleton w-1/3" />
        <div class="h-4 bg-surface-soft rounded skeleton w-1/5" />
        <div class="h-4 bg-surface-soft rounded skeleton w-1/6" />
      </div>
      {Array.from({ length: lines }).map(() => (
        <div class="flex gap-4">
          <div class="h-3.5 bg-surface-soft rounded skeleton w-1/4" />
          <div class="h-3.5 bg-surface-soft rounded skeleton w-1/3" />
          <div class="h-3.5 bg-surface-soft rounded skeleton w-1/5" />
          <div class="h-3.5 bg-surface-soft rounded skeleton w-1/6" />
        </div>
      ))}
    </div>
  )
}

{
  type === 'card' && (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {Array.from({ length: lines }).map(() => (
        <div class="border border-line rounded-lg p-4 space-y-3">
          <div class="h-4 bg-surface-soft rounded skeleton w-2/3" />
          <div class="h-3 bg-surface-soft rounded skeleton w-full" />
          <div class="h-3 bg-surface-soft rounded skeleton w-3/4" />
          <div class="h-8 bg-surface-soft rounded skeleton w-1/3 mt-2" />
        </div>
      ))}
    </div>
  )
}

{
  type === 'text' && (
    <div class="space-y-2">
      {Array.from({ length: lines }).map(i => (
        <div class={`h-3.5 bg-surface-soft rounded skeleton ${i === lines - 1 ? 'w-2/3' : 'w-full'}`} />
      ))}
    </div>
  )
}
