---
interface Props {
  current: number;
  total: number;
  baseUrl: string;
  preserveParams?: boolean;
}

const { current, total, baseUrl } = Astro.props;

function buildPageUrl(page: number): string {
  const url = new URL(baseUrl, 'http://x');
  url.searchParams.set('page', String(page));
  return url.pathname + url.search;
}

const pages: (number | '...')[] = [];
if (total <= 7) {
  for (let i = 1; i <= total; i++) pages.push(i);
} else {
  pages.push(1);
  if (current > 3) pages.push('...');
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) pages.push(i);
  if (current < total - 2) pages.push('...');
  pages.push(total);
}
---

<nav class="flex items-center justify-between pt-4" aria-label="Pagination">
  <p class="text-xs text-muted">
    Page {current} of {total}
  </p>
  <div class="flex items-center gap-1">
    {current > 1 && (
      <a href={buildPageUrl(current - 1)}
        class="px-3 py-1.5 text-xs font-semibold rounded-lg border border-line bg-surface text-ink-secondary hover:bg-surface-soft no-underline transition-colors">
        Previous
      </a>
    )}
    {pages.map(p => (
      p === '...' ? (
        <span class="px-2 text-xs text-muted">…</span>
      ) : (
        <a href={buildPageUrl(p as number)}
          class={`px-3 py-1.5 text-xs font-semibold rounded-lg no-underline transition-colors ${p === current ? 'bg-brand text-white' : 'bg-surface text-ink-secondary border border-line hover:bg-surface-soft'}`}>
          {p}
        </a>
      )
    ))}
    {current < total && (
      <a href={buildPageUrl(current + 1)}
        class="px-3 py-1.5 text-xs font-semibold rounded-lg border border-line bg-surface text-ink-secondary hover:bg-surface-soft no-underline transition-colors">
        Next
      </a>
    )}
  </div>
</nav>
