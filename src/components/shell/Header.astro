---
import { ThemeToggle } from "@/islands/ThemeToggle";
const facebookUrl = "https://www.facebook.com/zabirboutiques";
---

<header class="sticky top-0 z-40 border-b border-[var(--line)] glass">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 md:px-8 lg:px-16">
    <!-- Logo -->
    <a href="/" class="flex min-w-0 items-center gap-3 leading-tight" aria-label="Zabir Boutiques home">
      <span class="grid h-10 w-10 shrink-0 place-items-center overflow-hidden rounded-full bg-[var(--ink)] ring-2 ring-[var(--line)]">
        <img src="/assets/zabir-logo.jpg" alt="" width="40" height="40" class="h-full w-full object-cover" />
      </span>
      <span class="min-w-0 hidden sm:block">
        <strong class="block truncate text-base font-bold tracking-tight text-[var(--ink)]">Zabir Boutiques</strong>
        <span class="block truncate text-[11px] font-medium text-[var(--muted)]">Wari, Dhaka</span>
      </span>
    </a>

    <!-- Right actions -->
    <div class="flex items-center gap-2 sm:gap-3">
      <!-- Facebook: icon-only on mobile, text on sm+ -->
      <a href={facebookUrl} aria-label="Facebook page" class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--line)] bg-[var(--surface)] text-[var(--brand)] transition hover:border-[var(--brand)] hover:bg-[var(--brand-light)] sm:w-auto sm:px-4 sm:py-2">
        <svg class="h-4 w-4 sm:mr-1.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
        </svg>
        <span class="hidden text-xs font-semibold sm:inline">Facebook</span>
      </a>

      <!-- Call: icon-only on mobile, text on sm+ -->
      <a href="tel:+8801985516000" aria-label="Call us" class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--ink)] text-[var(--bg)] transition hover:opacity-90 active:scale-95 sm:w-auto sm:px-4 sm:py-2">
        <svg class="h-4 w-4 sm:mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
        </svg>
        <span class="hidden text-xs font-semibold sm:inline">Call</span>
      </a>

      <!-- Theme toggle -->
      <ThemeToggle client:idle />
    </div>
  </div>
</header>
