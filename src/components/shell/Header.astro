---
const facebookUrl = "https://www.facebook.com/zabirboutiques";
---

<header class="sticky top-0 z-40 border-b border-[var(--line)] bg-white/70 backdrop-blur-xl supports-[backdrop-filter]:bg-white/60">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 md:px-8 lg:px-16">
    <a href="/" class="flex min-w-0 items-center gap-3 leading-tight" aria-label="Zabir Boutiques home">
      <span class="grid h-10 w-10 shrink-0 place-items-center overflow-hidden rounded-full bg-[var(--ink)] ring-2 ring-[var(--line)]">
        <img src="/assets/zabir-logo.jpg" alt="" width="640" height="640" class="h-full w-full object-cover" />
      </span>
      <span class="min-w-0">
        <strong class="block truncate text-base font-bold tracking-tight">Zabir Boutiques</strong>
        <span class="block truncate text-[11px] font-medium text-[var(--muted)]">Wari, Dhaka</span>
      </span>
    </a>
    <div class="flex items-center gap-3">
      <a href={facebookUrl} class="hidden rounded-full border border-[var(--line)] bg-white px-4 py-2 text-xs font-semibold text-[var(--brand)] transition hover:border-[var(--brand)] hover:bg-[var(--brand-light)] sm:inline-flex">Facebook</a>
      <a href="tel:+8801985516000" class="rounded-full bg-[var(--ink)] px-4 py-2 text-xs font-semibold text-white transition hover:bg-zinc-700 active:scale-95">Call</a>
    </div>
  </div>
</header>
