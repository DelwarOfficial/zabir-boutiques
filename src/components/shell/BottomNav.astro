---
// src/components/shell/BottomNav.astro
// Static Astro component for mobile bottom navigation (replaces React island)
const pathname = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Home", match: (path: string) => path === "/" },
  { href: "/categories/pakistani-collection", label: "Shop", match: (path: string) => path.startsWith("/categories") },
  { href: "/checkout", label: "Cart", match: (path: string) => path.startsWith("/checkout") },
  { href: "/orders", label: "Orders", match: (path: string) => path.startsWith("/orders") },
];
---

<nav
  aria-label="Primary"
  class="fixed inset-x-0 bottom-0 z-50 md:hidden glass-nav safe-bottom pt-1.5 shadow-[0_-8px_30px_rgba(0,0,0,0.06)]"
>
  <div class="mx-auto grid max-w-md grid-cols-4 gap-1 px-1">
    {navItems.map((item) => {
      const active = item.match(pathname);
      return (
        <a
          href={item.href}
          aria-current={active ? "page" : undefined}
          class={`press tap-44 relative flex flex-col items-center justify-center rounded-2xl text-[10px] font-semibold transition-colors duration-200 ${
            active ? "text-[var(--brand)]" : "text-[var(--muted)] hover:text-[var(--ink)]"
          }`}
        >
          <span
            aria-hidden="true"
            class={`relative mb-0.5 grid h-7 w-7 place-items-center rounded-full transition-all duration-300 ${
              active ? "bg-[var(--brand-light)] scale-110" : "bg-transparent scale-100"
            }`}
          >
            {item.label === "Home" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={active ? 2.4 : 2} stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            )}
            {item.label === "Shop" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={active ? 2.4 : 2} stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
            )}
            {item.label === "Cart" && (
              <>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={active ? 2.4 : 2} stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span
                  id="bottom-cart-badge"
                  class="hidden absolute -right-1 -top-1 grid min-h-[16px] min-w-[16px] place-items-center rounded-full bg-[var(--brand)] px-1 text-[9px] font-bold text-white shadow-sm pop"
                >
                  0
                </span>
              </>
            )}
            {item.label === "Orders" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={active ? 2.4 : 2} stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/><path d="M14 8H8"/><path d="M16 12H8"/><path d="M13 16H8"/></svg>
            )}
          </span>
          <span class={active ? "opacity-100" : "opacity-90"}>{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>

<script is:inline>
  (function() {
    function updateBadge() {
      const badge = document.getElementById('bottom-cart-badge');
      if (!badge) return;
      try {
        const raw = localStorage.getItem('zb-cart');
        const cart = raw ? JSON.parse(raw) : [];
        const count = cart.reduce((sum, item) => sum + item.quantity, 0);
        if (count > 0) {
          const prevCount = badge.textContent;
          badge.textContent = count > 9 ? '9+' : count;
          badge.classList.remove('hidden');
          if (prevCount !== badge.textContent) {
            badge.classList.add('pop');
            setTimeout(() => badge.classList.remove('pop'), 300);
          }
        } else {
          badge.classList.add('hidden');
        }
      } catch {
        badge.classList.add('hidden');
      }
    }
    window.addEventListener('storage', updateBadge);
    window.addEventListener('zb-cart-updated', updateBadge);
    updateBadge();
  })();
</script>
