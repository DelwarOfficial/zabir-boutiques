---
const count = Astro.props.count ?? 4;
---

<div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4" aria-hidden="true">
  {Array.from({ length: count }).map(() => (
    <div class="shell-card p-2">
      <div class="skeleton aspect-[4/5] rounded-md"></div>
      <div class="mt-3 h-3 w-4/5 rounded-full skeleton"></div>
      <div class="mt-2 h-3 w-1/2 rounded-full skeleton"></div>
      <div class="mt-3 h-9 rounded-md skeleton"></div>
    </div>
  ))}
</div>
