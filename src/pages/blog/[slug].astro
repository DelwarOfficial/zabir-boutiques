---
import RootLayout from "@/layouts/RootLayout.astro";
import { BLOG_POSTS } from "@/data/blog-posts";

export const prerender = true;

export function getStaticPaths() {
  return BLOG_POSTS.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const site = Astro.site?.origin ?? 'https://zabirboutiques.com';
---

<RootLayout title={`${post.title} | Zabir Boutiques Blog`}>
  <article class="mx-auto max-w-3xl py-6">
    <p class="text-xs font-black uppercase tracking-[0.2em] text-[var(--brand)]">{post.category}</p>
    <h1 class="mt-2 text-3xl font-black">{post.title}</h1>
    <p class="mt-2 text-sm text-[var(--muted)]">{post.publishedAt}</p>
    <p class="mt-6 text-base leading-7 text-[var(--ink)]">{post.excerpt}</p>
    <link rel="canonical" href={`${site}/blog/${post.slug}`} />
  </article>
</RootLayout>