---
/**
 * /buy-now/[slug] — F-Commerce Direct Order Landing Page [Master Plan §10.4]
 *
 * Single-page conversion-focused layout matching Bangladesh F-commerce pattern.
 * Everything on one scroll: hero offer, image gallery, product benefits,
 * trust signals, order form, support CTA.
 */
import RootLayout from "@/layouts/RootLayout.astro";
import { BuyNowLandingForm } from "@/islands/BuyNowLandingForm";
import { formatPaisa } from "@/lib/money";
import type { DirectCheckoutState } from "@/lib/do-client";
import { env } from "cloudflare:workers";

const { slug } = Astro.params;
let sid = Astro.url.searchParams.get("sid");

// 1. Direct landing page access: generate session if sid is missing
if (!sid) {
  const product = await env.DB.prepare(
    `SELECT p.id, p.slug, p.name, p.price_paisa
     FROM products p
     WHERE p.slug = ?1 AND p.status = 'published'`
  ).bind(slug).first<{
    id: string; slug: string; name: string; price_paisa: number;
  }>();

  if (!product) {
    return Astro.redirect("/");
  }

  const queryVariantId = Astro.url.searchParams.get("variantId");
  let variantId = queryVariantId;

  if (!variantId) {
    const defaultVariant = await env.DB.prepare(
      `SELECT v.id FROM product_variants v WHERE v.product_id = ?1 AND v.is_deleted = 0 ORDER BY v.size, v.color LIMIT 1`
    ).bind(product.id).first<{ id: string }>();
    variantId = defaultVariant?.id ?? product.id;
  }

  const queryQty = Number(Astro.url.searchParams.get("quantity")) || 1;

  // Generate a new secure HMAC session ID
  const secret = env.SESSION_SECRET || "dev-session-secret-at-least-32-chars-long-for-hmac";
  const random = crypto.getRandomValues(new Uint8Array(32));
  const payload = `${Date.now()}:${Array.from(random, b => b.toString(16).padStart(2, '0')).join('')}`;
  const key = await crypto.subtle.importKey('raw', new TextEncoder().encode(secret), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
  const signature = await crypto.subtle.sign('HMAC', key, new TextEncoder().encode(payload));
  const sessionId = Array.from(new Uint8Array(signature), b => b.toString(16).padStart(2, '0')).join('');

  const now = new Date();
  if (env.DIRECT_CHECKOUT_DO) {
    const id = env.DIRECT_CHECKOUT_DO.idFromName(sessionId);
    const stub = env.DIRECT_CHECKOUT_DO.get(id);
    await stub.fetch('https://do/create', {
      method: 'POST',
      body: JSON.stringify({
        productId: product.id,
        variantId: variantId,
        quantity: queryQty,
        selectedOptions: {},
        sourcePage: `/products/${product.slug}`,
        utmParams: Object.fromEntries(Astro.url.searchParams),
        sessionId,
        origin: Astro.url.origin,
        userAgent: Astro.request.headers.get("User-Agent") ?? '',
      }),
    });
  } else {
    await env.DB.prepare(
      `INSERT INTO checkout_sessions (sessionId, productId, variantId, quantity, selectedOptions, createdAt)
       VALUES (?1, ?2, ?3, ?4, ?5, ?6)`
    ).bind(
      sessionId,
      product.id,
      variantId,
      queryQty,
      JSON.stringify({}),
      now.toISOString()
    ).run();
  }

  const newParams = new URLSearchParams(Astro.url.searchParams);
  newParams.set("sid", sessionId);
  return Astro.redirect(`/buy-now/${slug}?${newParams.toString()}`);
}

// 2. Load session from DirectCheckoutSessionDO or D1 database fallback
const turnstileSiteKey: string | undefined = env.TURNSTILE_SITE_KEY;
let session: DirectCheckoutState | null = null;

if (env.DIRECT_CHECKOUT_DO) {
  const id = env.DIRECT_CHECKOUT_DO.idFromName(sid);
  const stub = env.DIRECT_CHECKOUT_DO.get(id);
  const response = await stub.fetch("https://do/get", {
    method: "POST",
    body: JSON.stringify({
      sessionId: sid,
      origin: Astro.url.origin,
      userAgent: Astro.request.headers.get("User-Agent") ?? "",
    }),
  });
  const data = (await response.json().catch(() => null)) as { ok?: boolean; session?: DirectCheckoutState } | null;
  session = data?.ok ? data.session ?? null : null;
}

if (!session) {
  const row = await env.DB.prepare(
    `SELECT sessionId, productId, variantId, quantity, selectedOptions, sourcePage, utmParams, createdAt
     FROM checkout_sessions
     WHERE sessionId = ?1 AND deletedAt IS NULL`
  ).bind(sid).first<{
    sessionId: string;
    productId: string;
    variantId: string;
    quantity: number;
    selectedOptions: string | null;
    sourcePage: string | null;
    utmParams: string | null;
    createdAt: string;
  }>();

  if (row) {
    session = {
      sessionId: row.sessionId,
      productId: row.productId,
      variantId: row.variantId,
      quantity: row.quantity,
      selectedOptions: row.selectedOptions ? JSON.parse(row.selectedOptions) : {},
      sourcePage: row.sourcePage,
      utmParams: row.utmParams ? JSON.parse(row.utmParams) : null,
      createdAt: row.createdAt,
      expiresAt: new Date(new Date(row.createdAt).getTime() + 30 * 60 * 1000).toISOString(),
      landingVersion: 1,
      formDraft: null,
    };
  }
}

if (!session || new Date(session.expiresAt) < new Date()) {
  return Astro.redirect(`/products/${slug ?? ""}`);
}

const product = await env.DB.prepare(
  `SELECT p.id, p.slug, p.name, p.description, p.price_paisa, p.compare_price_paisa, p.status
   FROM products p
   WHERE p.slug = ?1 AND p.status = 'published'`
).bind(slug).first<{
  id: string; slug: string; name: string; description: string | null;
  price_paisa: number; compare_price_paisa: number | null; status: string;
}>();

if (!product || product.id !== session.productId) {
  return Astro.redirect(`/products/${slug ?? ""}`);
}

// Load ALL product images for gallery
const images = await env.DB.prepare(
  `SELECT id, r2_key, alt_text, width, height, sort_order
   FROM product_images WHERE product_id = ?1 ORDER BY sort_order ASC`
).bind(product.id).all<{ id: string; r2_key: string; alt_text: string | null; width: number | null; height: number | null; sort_order: number }>();

type ProductImage = { id: string; r2_key: string; alt_text: string | null; width: number | null; height: number | null; sort_order: number };
type ProductVariant = { id: string; size: string | null; color: string | null; sku: string; price_paisa: number };

const imageList: ProductImage[] = images.results ?? [];
const primaryImage = imageList[0]?.r2_key ?? "/assets/product-zb-stitch.svg";
const primaryAlt = imageList[0]?.alt_text ?? product.name;

// Load ALL variants for size/color options
const variants = await env.DB.prepare(
  `SELECT v.id, v.size, v.color, v.sku, COALESCE(v.price_paisa, p.price_paisa) AS price_paisa
   FROM product_variants v
   JOIN products p ON p.id = v.product_id
   WHERE v.product_id = ?1 AND v.is_deleted = 0
   ORDER BY v.size, v.color`
).bind(product.id).all<ProductVariant>();

const variantList: ProductVariant[] = variants.results ?? [];
const selectedVariant = variantList.find(v => v.id === session.variantId) ?? variantList[0];

// Delivery pricing
const INSIDE_DHAKA = 7000;
const OUTSIDE_DHAKA = 13000;

const variantLabel = [selectedVariant?.size, selectedVariant?.color].filter(Boolean).join(" / ") || "Standard";
const unitPrice = selectedVariant?.price_paisa ?? product.price_paisa;
const subtotalPaisa = unitPrice * session.quantity;
const hasDiscount = product.compare_price_paisa && product.compare_price_paisa > unitPrice;
const discountPercent = hasDiscount ? Math.round((1 - unitPrice / product.compare_price_paisa!) * 100) : 0;
const savingsPaisa = hasDiscount ? (product.compare_price_paisa! - unitPrice) : 0;
const site = Astro.site?.origin ?? "https://zabirboutiques.com";
const buyNowUrl = Astro.url.href;
const ogImage = primaryImage.startsWith("http") ? primaryImage : new URL(primaryImage, site).href;
const faqItems = [
  {
    question: "ডেলিভারি কত দিনে পাব?",
    answer: "ঢাকায় সাধারণত ১-৩ কার্যদিবস, ঢাকার বাইরে ২-৫ কার্যদিবস সময় লাগতে পারে।",
  },
  {
    question: "সাইজ ঠিক না হলে কী হবে?",
    answer: "সাইজ সমস্যা হলে এক্সচেঞ্জ সাপোর্ট থাকবে, তবে পণ্য অক্ষত রাখতে হবে।",
  },
  {
    question: "ক্যাশ অন ডেলিভারি আছে?",
    answer: "হ্যাঁ, পণ্য হাতে পেয়ে মূল্য পরিশোধ করতে পারবেন।",
  },
  {
    question: "অর্ডার কনফার্ম কিভাবে হবে?",
    answer: "ফর্ম পূরণ করার পর আমাদের টিম অর্ডার রিভিউ ও কনফার্ম করবে।",
  },
];
const productJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  image: [ogImage],
  description: product.description ?? `${product.name} at Zabir Boutiques`,
  sku: selectedVariant?.sku ?? selectedVariant?.id ?? product.id,
  brand: { "@type": "Brand", name: "Zabir Boutiques" },
  category: "Fashion",
  offers: {
    "@type": "Offer",
    price: (unitPrice / 100).toFixed(2),
    priceCurrency: "BDT",
    availability: "https://schema.org/InStock",
    url: buyNowUrl,
    seller: { "@type": "Organization", name: "Zabir Boutiques" },
    itemCondition: "https://schema.org/NewCondition",
  },
});
const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
});

// Parse product description into feature list
const features: string[] = (product.description ?? "")
  .split("\n")
  .map((l: string) => l.replace(/^[•\-\*]\s*/, "").trim())
  .filter((l: string) => l.length > 0);
---

<RootLayout title={`${product.name} | Zabir Boutiques`} description={product.description ?? product.name} ogImage={ogImage}>
  <Fragment slot="head">
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={buyNowUrl} />
    <script type="application/ld+json" set:html={productJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
  </Fragment>
  <article class="max-w-5xl mx-auto fade-up px-4 sm:px-6 pb-24">

    <style is:inline>
      article { position: relative; }
      article::before {
        content: "";
        position: absolute;
        inset: -2rem auto auto 12%;
        width: 240px;
        height: 240px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(184,134,11,.14), rgba(184,134,11,0));
        pointer-events: none;
        filter: blur(6px);
      }
      .bn-shell { display: grid; gap: 1.25rem; }
      .bn-card { background: color-mix(in srgb, var(--surface) 94%, #fff 6%); border: 1px solid color-mix(in srgb, var(--line) 82%, var(--brand) 18%); border-radius: 24px; box-shadow: 0 18px 48px rgba(15, 23, 42, 0.06); }
      .bn-pill { display:inline-flex; align-items:center; gap:.35rem; border-radius:999px; padding:.45rem .8rem; font-size:.75rem; font-weight:800; }
      .bn-grid { display:grid; gap:1rem; }
      .bn-trust { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.75rem; }
      .bn-trust div { background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 94%, #fff 6%), var(--surface)); border: 1px solid color-mix(in srgb, var(--line) 78%, var(--brand) 22%); border-radius: 18px; padding: .95rem; font-size: .85rem; font-weight: 700; }
      .bn-gallery { display:grid; gap:.75rem; }
      .bn-thumbs { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:.6rem; }
      .bn-checklist { display:grid; gap:.75rem; }
      .bn-checklist li { display:flex; gap:.65rem; align-items:flex-start; }
      .bn-checklist li span:first-child { flex-shrink:0; }
      .bn-reviews { display:grid; gap:.9rem; }
      .bn-eyebrow { letter-spacing: .2em; text-transform: uppercase; font-size: .72rem; font-weight: 900; color: var(--brand); }
      .bn-hero-copy { max-width: 32rem; }
      .bn-soft-panel { background: linear-gradient(180deg, color-mix(in srgb, var(--surface-soft) 86%, #fff 14%), var(--surface-soft)); }
      .bn-metric { border-radius: 18px; padding: .95rem 1rem; background: linear-gradient(180deg, rgba(184,134,11,.08), rgba(184,134,11,.02)); border: 1px solid rgba(184,134,11,.14); }
      .bn-faq details { border-top:1px solid var(--line); padding: .95rem 0; }
      .bn-faq details:first-child { border-top: 0; padding-top: 0; }
      .bn-faq summary { cursor:pointer; list-style:none; font-weight:800; }
      .bn-faq summary::-webkit-details-marker { display:none; }
      .bn-sticky-cta { position:fixed; left:0; right:0; bottom:0; z-index:40; padding:.75rem 1rem calc(.75rem + env(safe-area-inset-bottom)); background:linear-gradient(to top, var(--bg) 55%, rgba(255,255,255,0)); backdrop-filter: blur(8px); }
      .bn-sticky-cta a { display:flex; align-items:center; justify-content:center; min-height:52px; border-radius:999px; background:var(--brand); color:white; font-weight:900; text-decoration:none; box-shadow:0 16px 32px rgba(161,98,7,.24); }
      @media (min-width: 960px) {
        .bn-hero { grid-template-columns: 1.05fr .95fr; align-items: stretch; }
        .bn-main { grid-template-columns: minmax(0, 1fr) 390px; align-items:start; }
        .bn-trust { grid-template-columns:repeat(4,minmax(0,1fr)); }
        .bn-reviews { grid-template-columns:repeat(3,minmax(0,1fr)); }
        .bn-sticky-cta { display:none; }
      }
    </style>

    <div class="bn-shell">
      <section class="bn-card overflow-hidden bn-grid p-4 sm:p-6 bn-hero">
        <div class="flex flex-col justify-between gap-4">
          <div class="bn-hero-copy">
            <p class="bn-eyebrow mb-3">Curated Everyday Tailoring</p>
            <div class="flex flex-wrap gap-2 mb-3">
              {hasDiscount && <span class="bn-pill bg-[var(--danger)]/10 text-[var(--danger)]">🔥 {discountPercent}% ছাড়</span>}
              <span class="bn-pill bg-[var(--success)]/10 text-[var(--success)]">ক্যাশ অন ডেলিভারি</span>
            </div>
            <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight leading-tight">{product.name}</h1>
            <p class="mt-2 text-sm sm:text-base text-[var(--muted)]">প্রিমিয়াম ফ্যাব্রিক, স্মার্ট ফিট, আরামদায়ক পরিধান। {variantLabel} ভ্যারিয়েন্টে দ্রুত, ঝামেলাহীন, ট্রাস্ট-ফার্স্ট অর্ডার অভিজ্ঞতা।</p>

            <div class="mt-5 flex flex-wrap items-end gap-3">
              <span class="text-4xl sm:text-5xl font-extrabold text-[var(--brand)] tabular">{formatPaisa(unitPrice)}</span>
              {hasDiscount && <span class="text-lg sm:text-xl font-bold text-[var(--muted)] line-through tabular">{formatPaisa(product.compare_price_paisa!)}</span>}
            </div>

            {hasDiscount && (
              <p class="mt-2 text-sm font-bold text-[var(--danger)]">আজই অর্ডার করলে সাশ্রয় {formatPaisa(savingsPaisa)} পর্যন্ত।</p>
            )}

            <div class="mt-5 grid gap-3 sm:grid-cols-3 text-sm font-semibold text-[var(--ink-secondary)]">
              <div class="bn-metric">ঢাকার ভিতরে দ্রুত ডেলিভারি</div>
              <div class="bn-metric">সাইজ মিস হলে এক্সচেঞ্জ সাপোর্ট</div>
              <div class="bn-metric">Ad traffic-এর জন্য সহজ অর্ডার ফ্লো</div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href="#checkout" class="press inline-flex items-center justify-center rounded-full bg-[var(--brand)] px-6 h-12 text-sm font-extrabold text-white no-underline shadow-[0_16px_32px_rgba(161,98,7,0.25)]">এখনই অর্ডার করুন</a>
            <a href="https://wa.me/8801985516000" target="_blank" rel="noopener" class="press inline-flex items-center justify-center rounded-full border border-[var(--line)] bg-[var(--surface)] px-6 h-12 text-sm font-bold no-underline text-[var(--ink)]">WhatsApp এ জিজ্ঞেস করুন</a>
          </div>
        </div>

        <div class="bn-card bn-soft-panel p-3">
          <div class="aspect-[4/5] overflow-hidden rounded-[20px] bg-[var(--surface)]">
            <img
              src={primaryImage}
              alt={primaryAlt}
              width="900"
              height="1125"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              class="h-full w-full object-cover"
            />
          </div>
          {imageList.length > 1 && (
            <div class="bn-thumbs mt-3">
              {imageList.slice(0, 4).map((img) => (
                <div class="aspect-square overflow-hidden rounded-2xl border border-[var(--line)] bg-[var(--surface)]">
                  <img src={img.r2_key} alt={img.alt_text ?? product.name} width="240" height="240" loading="lazy" class="h-full w-full object-cover" />
                </div>
              ))}
            </div>
          )}
        </div>
      </section>

      <section class="bn-trust">
        <div>🚚 ঢাকা ৳60 / বাইরে ৳120</div>
        <div>💵 পণ্য হাতে পেয়ে মূল্য পরিশোধ</div>
        <div>📏 সাইজ সমস্যা হলে এক্সচেঞ্জ</div>
        <div>📞 কল / WhatsApp সাপোর্ট</div>
      </section>

      <section class="bn-main bn-grid">
        <div class="bn-grid">
          <section class="bn-card p-5 sm:p-6">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <div>
                <h2 class="text-xl font-extrabold">অফার স্ন্যাপশট</h2>
                <p class="mt-1 text-sm text-[var(--muted)]">দ্রুত সিদ্ধান্ত নেয়ার জন্য মূল তথ্য এক জায়গায়</p>
              </div>
              <span class="bn-pill bg-[var(--brand)]/10 text-[var(--brand)]">স্টক সীমিত</span>
            </div>
            <div class="grid sm:grid-cols-2 gap-3 mt-4 text-sm">
              <div class="rounded-2xl bn-soft-panel p-4"><strong>ভ্যারিয়েন্ট</strong><br />{variantLabel}</div>
              <div class="rounded-2xl bn-soft-panel p-4"><strong>অর্ডার টাইপ</strong><br />দ্রুত Buy Now</div>
              <div class="rounded-2xl bn-soft-panel p-4"><strong>ডেলিভারি</strong><br />২-৫ কার্যদিবস</div>
              <div class="rounded-2xl bn-soft-panel p-4"><strong>পেমেন্ট</strong><br />ক্যাশ অন ডেলিভারি</div>
            </div>
          </section>

          {imageList.length > 0 && (
            <section class="bn-card p-5 sm:p-6">
              <h2 class="text-xl font-extrabold mb-4">প্রোডাক্ট গ্যালারি</h2>
              <div class="flex gap-3 overflow-x-auto snap-x snap-mandatory rounded-2xl bg-[var(--surface-soft)] p-2 scrollbar-hide">
                {imageList.map((img, i) => (
                  <div class="snap-center shrink-0 w-[82%] sm:w-[46%] aspect-[4/5] overflow-hidden rounded-2xl bg-[var(--surface)]">
                    <img
                      src={img.r2_key}
                      alt={img.alt_text ?? product.name}
                      width={img.width ?? 800}
                      height={img.height ?? 1000}
                      loading={i === 0 ? "eager" : "lazy"}
                      decoding="async"
                      class="h-full w-full object-cover"
                    />
                  </div>
                ))}
              </div>
            </section>
          )}

          {features.length > 0 && (
            <section class="bn-card p-5 sm:p-6">
              <h2 class="text-xl font-extrabold mb-4">✨ কেন এই প্রোডাক্টটি ভালো</h2>
              <ul class="bn-checklist text-sm leading-6">
                {features.map((f) => (
                  <li>
                    <span class="text-[var(--success)]">✅</span>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <section class="bn-card p-5 sm:p-6">
            <h2 class="text-xl font-extrabold mb-4">📏 সাইজ ও ফিট গাইড</h2>
            <div class="grid gap-4 sm:grid-cols-[1.1fr_.9fr] items-start">
              <div class="rounded-2xl bn-soft-panel p-4 text-sm leading-6">
                <p class="font-bold">সাইজ নির্বাচন টিপস</p>
                <ul class="mt-2 space-y-2 text-[var(--ink-secondary)]">
                  <li>• আপনার নিয়মিত ব্যবহৃত প্যান্টের কোমর মেপে মিলিয়ে নিন</li>
                  <li>• লুজ ফিট চাইলে এক সাইজ আপ নিতে পারেন</li>
                  <li>• সাইজ মিস হলে এক্সচেঞ্জ সাপোর্ট রয়েছে</li>
                </ul>
              </div>
              <div class="rounded-2xl overflow-hidden border border-[var(--line)] bg-[var(--surface)]">
                <table class="w-full border-collapse text-sm">
                  <thead class="bg-[var(--surface-soft)] text-left">
                    <tr>
                      <th class="px-4 py-3 font-extrabold">সাইজ</th>
                      <th class="px-4 py-3 font-extrabold">কোমর (ইঞ্চি)</th>
                      <th class="px-4 py-3 font-extrabold">পরামর্শ</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="border-t border-[var(--line)]"><td class="px-4 py-3 font-bold">M</td><td class="px-4 py-3">30-31</td><td class="px-4 py-3">স্লিম ফিট</td></tr>
                    <tr class="border-t border-[var(--line)]"><td class="px-4 py-3 font-bold">L</td><td class="px-4 py-3">32-33</td><td class="px-4 py-3">রেগুলার ফিট</td></tr>
                    <tr class="border-t border-[var(--line)]"><td class="px-4 py-3 font-bold">XL</td><td class="px-4 py-3">34-35</td><td class="px-4 py-3">কমফোর্ট ফিট</td></tr>
                    <tr class="border-t border-[var(--line)]"><td class="px-4 py-3 font-bold">XXL</td><td class="px-4 py-3">36-37</td><td class="px-4 py-3">রুমিয়ার ফিট</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <section class="bn-card p-5 sm:p-6">
            <h2 class="text-xl font-extrabold mb-4">🛡️ আমাদের থেকে কেন নিবেন?</h2>
            <div class="grid gap-3 sm:grid-cols-2 text-sm">
               <div class="rounded-2xl bn-soft-panel p-4">✔️ ছবি ও বাস্তবের মিলের প্রতি জোর</div>
               <div class="rounded-2xl bn-soft-panel p-4">✔️ ক্যাশ অন ডেলিভারি সুবিধা</div>
               <div class="rounded-2xl bn-soft-panel p-4">✔️ সাইজ ছোট/বড় হলে এক্সচেঞ্জ সাপোর্ট</div>
               <div class="rounded-2xl bn-soft-panel p-4">✔️ কল / WhatsApp দিয়ে সরাসরি সাপোর্ট</div>
            </div>
          </section>

          <section class="bn-card p-5 sm:p-6">
            <h2 class="text-xl font-extrabold mb-4">🚚 ডেলিভারি তথ্য</h2>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div class="rounded-2xl bn-soft-panel p-4 text-center">
                <p class="font-bold">ঢাকার ভিতরে</p>
                <p class="text-2xl font-extrabold text-[var(--brand)] tabular">{formatPaisa(INSIDE_DHAKA)}</p>
              </div>
              <div class="rounded-2xl bn-soft-panel p-4 text-center">
                <p class="font-bold">ঢাকার বাইরে</p>
                <p class="text-2xl font-extrabold text-[var(--brand)] tabular">{formatPaisa(OUTSIDE_DHAKA)}</p>
              </div>
            </div>
          </section>

          <section class="bn-card p-5 sm:p-6">
            <h2 class="text-xl font-extrabold mb-4">💬 কাস্টমার ফিডব্যাক</h2>
            <div class="bn-reviews text-sm">
              <div class="rounded-2xl bn-soft-panel p-4"><strong>★★★★★</strong><p class="mt-2">ফিটিং অনেক ভালো, অফিসে পরার জন্য একদম পারফেক্ট।</p><p class="mt-2 text-[var(--muted)]">Tanvir, Dhaka</p></div>
              <div class="rounded-2xl bn-soft-panel p-4"><strong>★★★★★</strong><p class="mt-2">কাপড়টা আরামদায়ক, আর ডেলিভারিও দ্রুত ছিল।</p><p class="mt-2 text-[var(--muted)]">Hasib, Chattogram</p></div>
              <div class="rounded-2xl bn-soft-panel p-4"><strong>★★★★★</strong><p class="mt-2">সাইজ এক্সচেঞ্জ সাপোর্ট থাকায় নিশ্চিন্তে অর্ডার করতে পেরেছি।</p><p class="mt-2 text-[var(--muted)]">Rafi, Narayanganj</p></div>
            </div>
          </section>

          <section class="bn-card p-5 sm:p-6 bn-faq">
            <h2 class="text-xl font-extrabold mb-4">❓ সাধারণ প্রশ্ন</h2>
            <details open>
              <summary>ডেলিভারি কত দিনে পাব?</summary>
              <p class="mt-2 text-sm text-[var(--muted)]">ঢাকায় সাধারণত ১-৩ কার্যদিবস, ঢাকার বাইরে ২-৫ কার্যদিবস সময় লাগতে পারে।</p>
            </details>
            <details>
              <summary>সাইজ ঠিক না হলে কী হবে?</summary>
              <p class="mt-2 text-sm text-[var(--muted)]">সাইজ সমস্যা হলে এক্সচেঞ্জ সাপোর্ট থাকবে, তবে পণ্য অক্ষত রাখতে হবে।</p>
            </details>
            <details>
              <summary>ক্যাশ অন ডেলিভারি আছে?</summary>
              <p class="mt-2 text-sm text-[var(--muted)]">হ্যাঁ, পণ্য হাতে পেয়ে মূল্য পরিশোধ করতে পারবেন।</p>
            </details>
            <details>
              <summary>অর্ডার কনফার্ম কিভাবে হবে?</summary>
              <p class="mt-2 text-sm text-[var(--muted)]">ফর্ম পূরণ করার পর আমাদের টিম অর্ডার রিভিউ ও কনফার্ম করবে।</p>
            </details>
          </section>
        </div>

        <aside class="bn-grid">
          <section id="checkout" class="bn-card p-4 sm:p-5 sticky top-20">
            <div class="mb-4 text-center">
              <p class="text-xs font-extrabold uppercase tracking-wider text-[var(--brand)]">Fast Checkout</p>
              <h2 class="mt-1 text-xl font-extrabold">অর্ডার কনফার্ম করুন</h2>
              <p class="mt-1 text-sm text-[var(--muted)]">নাম, মোবাইল, ঠিকানা দিন। বাকিটা আমরা দ্রুত হ্যান্ডেল করব।</p>
            </div>

            <BuyNowLandingForm
              client:load
              sessionId={sid}
              productName={product.name}
              productImageUrl={primaryImage}
              variantLabel={variantLabel}
              unitPricePaisa={unitPrice}
              quantity={session.quantity}
              insideDhakaPaisa={INSIDE_DHAKA}
              outsideDhakaPaisa={OUTSIDE_DHAKA}
              initialDraft={session.formDraft}
              variants={variantList.map(v => ({ id: v.id, size: v.size, color: v.color, pricePaisa: v.price_paisa }))}
              selectedVariantId={selectedVariant?.id ?? ''}
              turnstileSiteKey={turnstileSiteKey}
            />
          </section>
        </aside>
      </section>

      <section class="bn-card p-5 sm:p-6 text-center">
        <p class="text-sm font-bold text-[var(--danger)]">স্টক দ্রুত শেষ হতে পারে। সিদ্ধান্ত নিতে সমস্যা হলে সরাসরি যোগাযোগ করুন।</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3 mt-4">
          <a href="tel:+8801985516000" class="press inline-flex items-center justify-center gap-2 rounded-full border border-[var(--line)] bg-[var(--surface)] px-5 h-12 text-sm font-bold no-underline text-[var(--ink)]">📞 কল করুন</a>
          <a href="https://wa.me/8801985516000" target="_blank" rel="noopener" class="press inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] text-white px-5 h-12 text-sm font-bold no-underline">💬 WhatsApp</a>
          <a href="#checkout" class="press inline-flex items-center justify-center gap-2 rounded-full bg-[var(--brand)] text-white px-5 h-12 text-sm font-extrabold no-underline">অর্ডার ফর্মে যান</a>
        </div>
      </section>
    </div>

    <div class="bn-sticky-cta md:hidden">
      <a href="#checkout">এখনই অর্ডার করুন · {formatPaisa(subtotalPaisa)}</a>
    </div>

  </article>
</RootLayout>
