---
import StaffLayout from '@/layouts/StaffLayout.astro';
import PageHeader from '@/components/staff/PageHeader.astro';
import { getCurrentStaffUser, isSuperAdmin } from '../../../lib/rbac';
import { getEnv } from '../../../lib/env';
import { readCsrfCookie } from '../../../lib/csrf';
import type { RoleWithPermissions } from '../../../types/rbac';
import RbacManager from '../../../islands/staff/RbacManager.tsx';

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect('/staff/login');
if (!isSuperAdmin(user.role)) return new Response('Forbidden', { status: 403 });

const env = getEnv(Astro);
let initialRoles: RoleWithPermissions[] = [];

try {
  const roles = await env.DB.prepare(
    `SELECT r.*,
       (SELECT COUNT(*) FROM staff_users WHERE role = r.name) as staff_count
     FROM roles r
     ORDER BY r.is_system DESC, r.name ASC`
  ).all<any>();

  const permRows = await env.DB.prepare(
    `SELECT role_id, permission FROM role_permissions ORDER BY role_id, permission`
  ).all<{ role_id: string; permission: string }>();

  const permMap = new Map<string, string[]>();
  for (const row of (permRows.results ?? [])) {
    const list = permMap.get(row.role_id);
    if (list) list.push(row.permission);
    else permMap.set(row.role_id, [row.permission]);
  }

  initialRoles = (roles.results ?? []).map((r: any) => ({
    ...r,
    permissions: permMap.get(r.id) ?? [],
    is_system: !!r.is_system,
    staff_count: r.staff_count ?? 0,
  }));
} catch (err) {
  console.error('Failed to load initial roles:', err);
}
---

<StaffLayout title="Roles & Permissions" user={user}>
  <PageHeader title="Roles & Permissions" subtitle="Create, edit, and manage roles and permissions" />
  <RbacManager client:load initialRoles={initialRoles} csrfToken={readCsrfCookie(Astro.request) ?? ''} />
</StaffLayout>
