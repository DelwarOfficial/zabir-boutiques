---
export const prerender = false;
import StaffLayout from "@/layouts/StaffLayout.astro";
import { getCurrentStaffUser, can } from "../../../lib/rbac";
import { getEnv } from "../../../lib/env";

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect("/staff/login");
if (!can(user.role, "support.view")) return new Response("Forbidden", { status: 403 });

const env = getEnv(Astro);
const recent = await env.DB.prepare(
  `SELECT o.id, o.order_number, o.name, o.phone, o.total_paisa, o.status, o.created_at
   FROM orders o ORDER BY o.created_at DESC LIMIT 20`
).all<any>();
---
<StaffLayout title="Support" user={user}>
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
    <h1 style="margin:0;font-size:1.25rem;font-weight:700;">Support</h1>
    <a href="/staff/support/search" style="padding:0.4rem 0.75rem;background:var(--brand);color:#fff;border-radius:6px;text-decoration:none;font-size:0.85rem;font-weight:600;">Search Orders</a>
  </div>
  <div style="overflow-x:auto;border:1px solid var(--line);border-radius:8px;">
    <table style="width:100%;border-collapse:collapse;font-size:0.85rem;">
      <thead><tr style="background:var(--surface-soft);text-align:left;">
        <th style="padding:0.6rem 0.75rem;font-weight:600;">Order</th>
        <th style="padding:0.6rem 0.75rem;font-weight:600;">Customer</th>
        <th style="padding:0.6rem 0.75rem;font-weight:600;">Total</th>
        <th style="padding:0.6rem 0.75rem;font-weight:600;">Status</th>
        <th style="padding:0.6rem 0.75rem;font-weight:600;">Date</th>
      </tr></thead>
      <tbody>
        {recent.results?.map(o => <tr style="border-top:1px solid var(--line-soft);">
          <td style="padding:0.6rem 0.75rem;"><a href={`/staff/orders/${o.id}`} style="color:var(--brand);text-decoration:none;font-weight:600;">{o.order_number}</a></td>
          <td style="padding:0.6rem 0.75rem;">{o.name}<br /><span style="color:var(--muted);font-size:0.8em;">{o.phone}</span></td>
          <td style="padding:0.6rem 0.75rem;font-weight:600;">৳{(o.total_paisa/100).toFixed(2)}</td>
          <td style="padding:0.6rem 0.75rem;">{o.status.replace(/_/g, ' ')}</td>
          <td style="padding:0.6rem 0.75rem;color:var(--muted);font-size:0.8em;">{o.created_at?.split(' ')[0]}</td>
        </tr>)} || <tr><td colspan="5" style="padding:2rem;text-align:center;color:var(--muted);">No orders yet.</td></tr>}
      </tbody>
    </table>
  </div>
</StaffLayout>