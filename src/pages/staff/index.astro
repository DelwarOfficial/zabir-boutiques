---
export const prerender = false;

import StaffLayout from "@/layouts/StaffLayout.astro";
import { getCurrentStaffUser, can } from "../../lib/rbac";
import { getEnv } from "../../lib/env";
import { nowSql } from "../../lib/dates";

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect("/staff/login");

const env = getEnv(Astro);
const today = nowSql().slice(0, 10);

const roleLabel: Record<string, string> = {
  super_admin: "Super Admin", owner: "Owner", manager: "Manager",
  salesman: "Sales Staff", packing: "Packing Staff", support: "Support",
};

let stats = { pendingReview: 0, packingQueue: 0, lowStockAlerts: 0, todayOrders: 0 };
let recentOrders: any[] = [];
let flagged: any[] = [];
let dbError = "";

try {
  const pr = await env.DB.prepare(`SELECT COUNT(*) as c FROM orders WHERE status = 'pending_review'`).first<{c:number}>();
  if (pr) stats.pendingReview = pr.c;
  const pq = await env.DB.prepare(`SELECT COUNT(*) as c FROM orders WHERE status IN ('staff_confirmed','packing')`).first<{c:number}>();
  if (pq) stats.packingQueue = pq.c;
  const ls = await env.DB.prepare(`SELECT COUNT(*) as c FROM low_stock_alerts WHERE is_acknowledged = 0`).first<{c:number}>();
  if (ls) stats.lowStockAlerts = ls.c;
  const td = await env.DB.prepare(`SELECT COUNT(*) as c FROM orders WHERE created_at >= ?`).bind(today + " 00:00:00").first<{c:number}>();
  if (td) stats.todayOrders = td.c;

  const ro = await env.DB.prepare(`SELECT id, order_number, name, total_paisa, status, created_at FROM orders ORDER BY created_at DESC LIMIT 6`).all<any>();
  if (ro?.results) recentOrders = ro.results;

  const fl = await env.DB.prepare(`SELECT id, order_number, name, fraud_decision FROM orders WHERE fraud_decision IN ('review','blocked') ORDER BY created_at DESC LIMIT 5`).all<any>();
  if (fl?.results) flagged = fl.results;
} catch (e: any) {
  dbError = e?.message ?? "Database query failed";
}

const perms = {
  orders: can(user.role, "orders.view"),
  products: can(user.role, "products.manage"),
  fraud: can(user.role, "fraud.view"),
  sales: ["salesman", "manager", "owner", "super_admin"].includes(user.role),
  packing: user.role === "packing" || can(user.role, "orders.pack"),
};
---

<StaffLayout title="Dashboard" user={user}>
  <div class="flex items-center justify-between mb-5">
    <div>
      <h1 class="m-0 text-2xl font-bold">Dashboard</h1>
      <p class="mt-1 text-muted">Welcome back, {user.fullName} · {roleLabel[user.role] ?? user.role}</p>
    </div>
    <div class="text-xs text-muted text-right">{today}</div>
  </div>

  {dbError && <div class="bg-red-100 text-red-800 px-4 py-2 rounded-md text-sm mb-4">{dbError}</div>}

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
    <div class="bg-surface border border-line rounded-lg p-4">
      <div class="text-[10px] uppercase tracking-wider text-muted">Today's Orders</div>
      <div class="text-3xl font-semibold mt-0.5">{stats.todayOrders}</div>
    </div>
    <div class="bg-surface border border-line rounded-lg p-4">
      <div class="text-[10px] uppercase tracking-wider text-muted">Pending Review</div>
      <div class="text-3xl font-semibold mt-0.5 text-amber-600">{stats.pendingReview}</div>
    </div>
    <div class="bg-surface border border-line rounded-lg p-4">
      <div class="text-[10px] uppercase tracking-wider text-muted">Packing Queue</div>
      <div class="text-3xl font-semibold mt-0.5 text-cyan-600">{stats.packingQueue}</div>
    </div>
    <div class="bg-surface border border-line rounded-lg p-4">
      <div class="text-[10px] uppercase tracking-wider text-muted">Low Stock Alerts</div>
      <div class="text-3xl font-semibold mt-0.5 text-red-600">{stats.lowStockAlerts}</div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 mb-6">
    <div class="lg:col-span-3 bg-surface border border-line rounded-lg p-4">
      <div class="flex justify-between items-center mb-2">
        <h2 class="m-0 text-base font-semibold">Recent Orders</h2>
        {perms.orders && <a href="/staff/orders" class="text-sm text-brand no-underline hover:underline">View all →</a>}
      </div>
      {recentOrders.length > 0 ? (
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <tbody>
              {recentOrders.map(o => (
                <tr class="border-t border-line-soft">
                  <td class="py-1.5"><a href={`/staff/orders/${o.id}`} class="text-brand font-medium no-underline">{o.order_number}</a></td>
                  <td class="py-1.5 text-muted">{o.name}</td>
                  <td class="py-1.5 text-right font-medium">৳{(o.total_paisa/100).toFixed(0)}</td>
                  <td class="py-1.5 pl-2 text-xs text-muted">{o.created_at?.split(" ")[0]}</td>
                  <td class="py-1.5"><span class="text-[10px] px-1.5 py-px rounded bg-line-soft text-ink-secondary">{o.status.replace(/_/g," ")}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : <p class="text-muted text-sm my-2">No orders yet.</p>}
    </div>

    <div class="lg:col-span-2 bg-surface border border-line rounded-lg p-4">
      <h2 class="m-0 mb-2 text-base font-semibold">Attention Needed</h2>
      {flagged.length > 0 && perms.fraud
        ? <ul class="text-sm pl-4 m-0">{flagged.map(f => <li class="mb-1"><a href={`/staff/orders/${f.id}`} class="text-brand">{f.order_number}</a> — {f.name} <span class="text-amber-700 text-xs">({f.fraud_decision})</span></li>)}</ul>
        : <p class="text-muted text-sm m-0">No fraud flags.</p>}

      <div class="mt-3 pt-3 border-t border-line">
        <div class="text-xs text-muted mb-1.5">Quick Actions</div>
        <div class="flex flex-wrap gap-2 text-sm">
          {perms.sales && <a href="/staff/sales/new" class="px-2.5 py-1 bg-brand text-white rounded text-xs no-underline font-medium">+ New Order</a>}
          {perms.sales && <a href="/staff/sales/instore" class="px-2.5 py-1 bg-surface border border-line rounded text-xs no-underline">In-Store Sale</a>}
          {perms.packing && <a href="/staff/packing" class="px-2.5 py-1 bg-surface border border-line rounded text-xs no-underline">Packing Queue</a>}
          {perms.products && <a href="/staff/products" class="px-2.5 py-1 bg-surface border border-line rounded text-xs no-underline">Products</a>}
          {perms.orders && <a href="/staff/orders" class="px-2.5 py-1 bg-surface border border-line rounded text-xs no-underline">All Orders</a>}
          <a href="/staff/support" class="px-2.5 py-1 bg-surface border border-line rounded text-xs no-underline">Support</a>
        </div>
      </div>
    </div>
  </div>

  <p class="text-muted text-xs mt-4">All staff actions are audited. Use the left navigation for your full toolset.</p>
</StaffLayout>