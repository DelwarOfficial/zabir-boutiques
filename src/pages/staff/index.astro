---
/**
 * Staff Dashboard — SSR [v6.8A]
 * Server-side session check + role-aware menu. RBAC enforced on every route.
 */
export const prerender = false;

import { getCurrentStaffUser } from '../../lib/rbac';
import { menuForRole } from '../../lib/staff-menu';

const user = await getCurrentStaffUser(Astro);

if (!user) {
  return Astro.redirect('/staff/login');
}

const menu = menuForRole(user.role);
const roleLabel: Record<string, string> = {
  super_admin: 'Super Admin',
  owner: 'Owner',
  manager: 'Manager',
  salesman: 'Sales Staff',
  packing: 'Packing Staff',
  support: 'Support'
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Staff Dashboard — Zabir Boutiques</title>
  </head>
  <body>
    <header style="display:flex;justify-content:space-between;align-items:center;padding:1rem;border-bottom:1px solid #ddd;">
      <strong>Zabir Boutiques — Staff</strong>
      <span style="display:flex;align-items:center;gap:1rem;">
        <span>{user.fullName} · {roleLabel[user.role] ?? user.role}</span>
        <button id="logout-btn" type="button">Sign out</button>
      </span>
    </header>
    <div style="display:flex;gap:2rem;padding:1rem;">
      <nav aria-label="Staff navigation" style="min-width:220px;">
        <ul style="list-style:none;padding:0;">
          {menu.map((item) => (
            <li style="margin:0.4rem 0;"><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
      <main style="flex:1;">
        <h1>Dashboard</h1>
        <p>Welcome, {user.fullName}. You are signed in as <strong>{roleLabel[user.role] ?? user.role}</strong>.</p>
        <p>Use the navigation to access your authorized areas. All actions are server-side RBAC protected and audit-logged.</p>
      </main>
    </div>
    <script is:inline>
      // Logout via double-submit CSRF: send the non-HttpOnly csrf-token cookie
      // back as the X-CSRF-Token header (required by middleware for non-GET
      // /api/staff/* routes).
      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        const match = document.cookie.match(/(?:^|;\s*)csrf-token=([^;]+)/);
        const csrf = match ? decodeURIComponent(match[1]) : '';
        await fetch('/api/staff/logout', {
          method: 'POST',
          headers: { 'X-CSRF-Token': csrf }
        });
        window.location.href = '/staff/login';
      });
    </script>
  </body>
</html>
