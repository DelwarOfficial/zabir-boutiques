---
import StaffLayout from "@/layouts/StaffLayout.astro";
import { getCurrentStaffUser, can } from "../../lib/rbac";
import { getEnv } from "../../lib/env";
import { nowSql } from "../../lib/dates";
import { MetricCard } from "@/components/staff/dashboard/MetricCard";
import Card from "@/components/staff/ui/Card.astro";
import Badge from "@/components/staff/ui/Badge.astro";
import EmptyState from "@/components/staff/ui/EmptyState.astro";
import PageHeader from "@/components/staff/PageHeader.astro";

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect("/staff/login");

const env = getEnv(Astro);
const today = nowSql().slice(0, 10);

const roleLabel: Record<string, string> = {
  super_admin: "Super Admin", owner: "Owner", manager: "Manager",
  salesman: "Sales Staff", packing: "Packing Staff", support: "Support",
  developer: "Developer", auditor: "Auditor",
};

const hour = new Date().getHours();
const greeting = hour < 5 ? "Working late" : hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening";

let stats = { pendingReview: 0, packingQueue: 0, lowStockAlerts: 0, todayOrders: 0, todayRevenue: 0 };
let recentOrders: any[] = [];
let flagged: any[] = [];
let dbError = "";

try {
  const pr = await env.DB.prepare(`SELECT COUNT(*) as c FROM orders WHERE status = 'pending_review'`).first<{c:number}>();
  if (pr) stats.pendingReview = pr.c;
  const pq = await env.DB.prepare(`SELECT COUNT(*) as c FROM orders WHERE status IN ('staff_confirmed','packing')`).first<{c:number}>();
  if (pq) stats.packingQueue = pq.c;
  const ls = await env.DB.prepare(`SELECT COUNT(*) as c FROM low_stock_alerts WHERE is_acknowledged = 0`).first<{c:number}>();
  if (ls) stats.lowStockAlerts = ls.c;
  const td = await env.DB.prepare(`SELECT COUNT(*) as c, COALESCE(SUM(total_paisa),0) as rev FROM orders WHERE created_at >= ?`).bind(today + " 00:00:00").first<{c:number, rev:number}>();
  if (td) { stats.todayOrders = td.c; stats.todayRevenue = td.rev ?? 0; }

  const ro = await env.DB.prepare(`SELECT id, order_number, name, total_paisa, status, created_at FROM orders ORDER BY created_at DESC LIMIT 6`).all<any>();
  if (ro?.results) recentOrders = ro.results;

  const fl = await env.DB.prepare(`SELECT id, order_number, name, fraud_decision FROM orders WHERE fraud_decision IN ('review','blocked') ORDER BY created_at DESC LIMIT 5`).all<any>();
  if (fl?.results) flagged = fl.results;
} catch (e: any) {
  dbError = e?.message ?? "Database query failed";
}

const perms = {
  orders: can(user.role, "orders.view"),
  products: can(user.role, "products.manage"),
  fraud: can(user.role, "fraud.view"),
  sales: ["salesman", "manager", "owner", "super_admin"].includes(user.role),
  packing: user.role === "packing" || can(user.role, "orders.pack"),
  security: ["owner", "super_admin"].includes(user.role),
};
---

<StaffLayout title="Dashboard" user={user}>
  <p class="text-[11px] font-extrabold uppercase tracking-wider text-brand mb-0 fade-up">{greeting}</p>
  <PageHeader title={user.fullName} subtitle={`${roleLabel[user.role] ?? user.role} · ${today}`} />

  {dbError && <div class="bg-red-100 text-red-800 px-4 py-2 rounded-md text-sm mb-4">{dbError}</div>}

  <div class="stagger grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
    <MetricCard title="Today's orders" value={stats.todayOrders} description={`৳ ${(stats.todayRevenue / 100).toFixed(0)} revenue`} />
    <MetricCard title="Pending review" value={stats.pendingReview} description="orders waiting" />
    <MetricCard title="Packing queue" value={stats.packingQueue} description="ready to pack" />
    <MetricCard title="Low-stock alerts" value={stats.lowStockAlerts} description="needs restock" />
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 mb-6">
    <div class="lg:col-span-3 fade-up">
      <Card title="Recent orders">
        {perms.orders && (
          <a slot="action" href="/staff/orders" class="press text-sm font-bold text-brand hover:opacity-80 no-underline">View all →</a>
        )}
        {recentOrders.length > 0 ? (
          <>
            <ul class="grid sm:hidden gap-2 stagger">
              {recentOrders.map(o => (
                <li>
                  <a href={`/staff/orders/${o.id}`} class="press flex items-center justify-between gap-3 rounded-xl border border-line p-3 no-underline">
                    <div class="min-w-0">
                      <p class="font-bold text-sm tabular text-brand">{o.order_number}</p>
                      <p class="text-xs text-muted truncate">{o.name}</p>
                    </div>
                    <div class="text-right shrink-0">
                      <p class="font-extrabold tabular">৳{(o.total_paisa/100).toFixed(0)}</p>
                      <Badge variant="default">{String(o.status).replace(/_/g, " ")}</Badge>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
            <div class="hidden sm:block">
              <table class="w-full text-sm border-collapse">
                <tbody>
                  {recentOrders.map(o => (
                    <tr class="border-t border-line-soft hover:bg-surface-soft transition-colors">
                      <td class="py-2"><a href={`/staff/orders/${o.id}`} class="text-brand font-bold no-underline">{o.order_number}</a></td>
                      <td class="py-2 text-muted">{o.name}</td>
                      <td class="py-2 text-right font-bold tabular">৳{(o.total_paisa/100).toFixed(0)}</td>
                      <td class="py-2 pl-2 text-xs text-muted">{o.created_at?.split(" ")[0]}</td>
                      <td class="py-2"><Badge variant="default">{o.status.replace(/_/g," ")}</Badge></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        ) : (
          <EmptyState icon="package" title="No orders yet" description="Orders will appear here once customers start placing them." />
        )}
      </Card>
    </div>

    <div class="lg:col-span-2 fade-up">
      <Card title="Attention needed">
        {flagged.length > 0 && perms.fraud ? (
          <ul class="text-sm pl-0 m-0 space-y-1.5 stagger">
            {flagged.map(f => (
              <li class="flex items-center gap-2">
                <a href={`/staff/orders/${f.id}`} class="text-brand font-bold no-underline">{f.order_number}</a>
                <span class="text-muted truncate">{f.name}</span>
                <span class="ml-auto"><Badge variant={f.fraud_decision === "blocked" ? "danger" : "warning"}>{f.fraud_decision}</Badge></span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-muted text-sm m-0">No fraud flags.</p>
        )}

        <div class="mt-4 pt-4 border-t border-line">
          <p class="text-xs font-extrabold uppercase tracking-wider text-muted mb-2">Quick actions</p>
          <div class="flex flex-wrap gap-2 text-sm">
            {perms.sales && <a href="/staff/sales/new" class="press tap-44 inline-flex items-center gap-1 rounded-full bg-brand text-white px-3 h-9 text-xs font-bold no-underline">+ New order</a>}
            {perms.sales && <a href="/staff/sales/instore" class="press tap-44 inline-flex items-center gap-1 rounded-full border border-line bg-surface px-3 h-9 text-xs font-bold text-ink no-underline">In-store</a>}
            {perms.packing && <a href="/staff/packing" class="press tap-44 inline-flex items-center gap-1 rounded-full border border-line bg-surface px-3 h-9 text-xs font-bold text-ink no-underline">Packing</a>}
            {perms.products && <a href="/staff/products" class="press tap-44 inline-flex items-center gap-1 rounded-full border border-line bg-surface px-3 h-9 text-xs font-bold text-ink no-underline">Products</a>}
            {perms.orders && <a href="/staff/orders" class="press tap-44 inline-flex items-center gap-1 rounded-full border border-line bg-surface px-3 h-9 text-xs font-bold text-ink no-underline">All orders</a>}
            <a href="/staff/support" class="press tap-44 inline-flex items-center gap-1 rounded-full border border-line bg-surface px-3 h-9 text-xs font-bold text-ink no-underline">Support</a>
            {perms.security && <a href="/staff/settings/totp" class="press tap-44 inline-flex items-center gap-1 rounded-full border border-brand bg-surface px-3 h-9 text-xs font-bold text-brand no-underline">Security / 2FA</a>}
          </div>
        </div>
      </Card>
    </div>
  </div>

  <p class="text-muted text-xs mt-4 flex items-center gap-1.5">
    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2l8 4v6c0 5-3.5 9.4-8 10-4.5-.6-8-5-8-10V6z"/></svg>
    All staff actions are audited. Use the left navigation for your full toolset.
  </p>
</StaffLayout>
