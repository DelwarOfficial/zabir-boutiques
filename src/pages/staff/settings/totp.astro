---
import StaffLayout from "@/layouts/StaffLayout.astro";
import { getCurrentStaffUser, requireRole } from "@/lib/rbac";
import { getEnv } from "@/lib/env";
import { generateTotpSecret } from "@/lib/totp";
import QRCode from "qrcode";
const user = await getCurrentStaffUser(Astro);
requireRole(user!, ["owner"]);

const env = getEnv(Astro);
const dbUser = await env.DB.prepare(
  `SELECT id, email, totp_secret, totp_required FROM staff_users WHERE id = ?1 LIMIT 1`
).bind(user!.id).first<{ id: string; email: string | null; totp_secret: string | null; totp_required: number }>();
const email = dbUser?.email ?? `${user!.id}@zabir.local`;
const { secret, uri } = generateTotpSecret(email);
const qrDataUrl = await QRCode.toDataURL(uri, { width: 280, margin: 1.5, color: { dark: "#1a1816", light: "#0000" } });
const totpEnabled = dbUser?.totp_required === 1 && !!dbUser?.totp_secret;
---

<StaffLayout title="Two-Factor Authentication" user={user!}>
  <div style="max-width:560px;margin:0 auto;">
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:2rem;">
      <div style="width:40px;height:40px;border-radius:10px;background:rgba(184,134,11,0.1);display:flex;align-items:center;justify-content:center;font-size:1.25rem;">&#128274;</div>
      <div>
        <h1 style="margin:0;font-size:1.35rem;font-weight:800;letter-spacing:-0.3px;">Two-Factor Authentication</h1>
        <p style="margin:0.1rem 0 0;color:var(--ink-secondary);font-size:0.85rem;">Protect your account with an authenticator app</p>
      </div>
    </div>

    {totpEnabled ? (
      <!-- Already enabled -->
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:1.5rem;text-align:center;">
        <div style="font-size:2.5rem;margin-bottom:0.75rem;">&#9989;</div>
        <h2 style="margin:0 0 0.5rem;font-size:1.1rem;color:var(--success);">2FA is active</h2>
        <p style="color:var(--ink-secondary);font-size:0.85rem;margin:0 0 1rem;">Your account is secured with two-factor authentication.</p>
        <button id="disable-btn" class="btn-ghost" style="color:var(--error);border:1px solid rgba(220,38,38,0.2);padding:0.5rem 1.25rem;border-radius:8px;cursor:pointer;font-size:0.8rem;background:transparent;">Disable 2FA</button>
      </div>
    ) : (
      <!-- Enrollment flow -->
      <div id="step-setup" class="step-view">
        <div style="background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:1.5rem;">

          <div style="display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.25rem;">
            <div style="width:28px;height:28px;border-radius:50%;background:var(--brand);color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;flex-shrink:0;">1</div>
            <div>
              <h3 style="margin:0 0 0.25rem;font-size:0.95rem;">Scan this QR code</h3>
              <p style="margin:0;color:var(--ink-secondary);font-size:0.8rem;">Open your authenticator app and scan the code below</p>
            </div>
          </div>

          <div style="display:flex;justify-content:center;margin:1rem 0 1.25rem;">
            <img src={qrDataUrl} alt="TOTP QR Code" style="border-radius:8px;width:200px;height:200px;image-rendering:pixelated;" />
          </div>

          <div style="display:flex;gap:1rem;align-items:flex-start;margin-bottom:0.75rem;">
            <div style="width:28px;height:28px;border-radius:50%;background:var(--brand);color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;flex-shrink:0;">2</div>
            <div>
              <h3 style="margin:0 0 0.25rem;font-size:0.95rem;">Or enter this key manually</h3>
              <p style="margin:0;color:var(--ink-secondary);font-size:0.8rem;">If you can't scan the QR code</p>
            </div>
          </div>

          <div style="background:var(--bg);border:1px solid var(--line);border-radius:8px;padding:0.75rem 1rem;display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;font-family:'SF Mono','Cascadia Code','Consolas',monospace;font-size:0.85rem;letter-spacing:1px;">
            <span id="secret-key" style="color:var(--ink);font-weight:600;">{secret}</span>
            <button id="copy-btn" class="tap-44" style="background:none;border:none;cursor:pointer;color:var(--brand);font-size:0.75rem;font-weight:600;padding:0.25rem 0.5rem;border-radius:6px;">Copy</button>
          </div>

          <div style="display:flex;gap:1rem;align-items:flex-start;">
            <div style="width:28px;height:28px;border-radius:50%;background:var(--brand);color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;flex-shrink:0;">3</div>
            <div style="flex:1;">
              <h3 style="margin:0 0 0.5rem;font-size:0.95rem;">Verify the code</h3>
              <p style="margin:0 0 0.75rem;color:var(--ink-secondary);font-size:0.8rem;">Enter the 6-digit code from your authenticator app to confirm</p>
              <div class="digit-grid" id="verify-grid" style="display:flex;gap:6px;justify-content:center;margin:0 0 0.75rem;">
                <input class="digit-box" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="0" />
                <input class="digit-box" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="1" />
                <input class="digit-box" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="2" />
                <input class="digit-box" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="3" />
                <input class="digit-box" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="4" />
                <input class="digit-box" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="5" />
              </div>
              <p id="verify-error" style="color:var(--error);font-size:0.8rem;text-align:center;margin:0 0 0.5rem;display:none;"></p>
              <button id="verify-btn" class="brand-btn" disabled>Verify &amp; Enable</button>
            </div>
          </div>
        </div>
      </div>
    )}
  </div>
</StaffLayout>

<style is:global>
  .step-view { transition:opacity 0.2s; }
  .digit-box {
    width:44px;height:50px;text-align:center;font-size:1.35rem;font-weight:700;
    border:2px solid var(--line);border-radius:8px;background:var(--surface);color:var(--ink);
    outline:none;transition:all 0.15s;caret-color:var(--brand);
  }
  .digit-box:focus { border-color:var(--brand); box-shadow:0 0 0 3px rgba(184,134,11,0.15); transform:translateY(-2px); }
  .digit-box.filled { border-color:var(--brand); background:rgba(184,134,11,0.06); }
  .brand-btn {
    width:100%;padding:0.65rem;background:var(--brand);color:#fff;border:none;
    border-radius:8px;font-size:0.9rem;font-weight:600;cursor:pointer;
    transition:background 0.15s, transform 0.1s;
  }
  .brand-btn:hover:not(:disabled) { background:var(--brand-hover); }
  .brand-btn:active:not(:disabled) { transform:scale(0.98); }
  .brand-btn:disabled { opacity:0.5; cursor:not-allowed; }
  .btn-ghost { transition:all 0.15s; }
  .btn-ghost:hover { background:rgba(220,38,38,0.06); }
  .shake { animation:shake 0.3s ease; }
  @keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-6px)} 75%{transform:translateX(6px)} }
  .tap-44 { min-width:44px;min-height:44px;display:inline-flex;align-items:center;justify-content:center; }
  .success-toast {
    position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);
    background:var(--success);color:#fff;padding:0.75rem 1.5rem;border-radius:10px;
    font-size:0.85rem;font-weight:600;box-shadow:0 4px 24px rgba(0,0,0,0.15);
    z-index:999;animation:fadeInUp 0.3s ease;
  }
  @keyframes fadeInUp { from{opacity:0;transform:translateX(-50%) translateY(12px)} to{opacity:1;transform:translateX(-50%) translateY(0)} }
  .spinner { display:inline-block; width:16px; height:16px; border:2px solid rgba(255,255,255,0.3);
    border-top-color:#fff; border-radius:50%; animation:spin 0.6s linear; vertical-align:middle; margin-right:6px; }
  @keyframes spin { to{transform:rotate(360deg)} }
</style>

<script is:inline>
  (function() {
    const secret = document.getElementById('secret-key')?.textContent || '';
    const verifyGrid = document.getElementById('verify-grid');
    if (!verifyGrid) return;

    const inputs = Array.from(verifyGrid.querySelectorAll('.digit-box'));
    const verifyBtn = document.getElementById('verify-btn');
    const verifyErr = document.getElementById('verify-error');

    function focusNext(idx) { if (idx < 5) inputs[idx + 1].focus(); }
    function focusPrev(idx) { if (idx > 0) inputs[idx - 1].focus(); }
    function getCode() { return inputs.map(inp => inp.value).join(''); }

    function updateVerifyBtn() {
      const full = getCode().length === 6;
      verifyBtn.disabled = !full;
    }

    inputs.forEach((inp, idx) => {
      inp.addEventListener('input', function() {
        this.value = this.value.replace(/[^0-9]/g, '').slice(0, 1);
        this.className = 'digit-box' + (this.value ? ' filled' : '');
        if (this.value) focusNext(idx);
        updateVerifyBtn();
      });
      inp.addEventListener('keydown', function(e) {
        if (e.key === 'Backspace' && !this.value) { e.preventDefault(); focusPrev(idx); }
        if (e.key === 'ArrowLeft') { e.preventDefault(); focusPrev(idx); }
        if (e.key === 'ArrowRight') { e.preventDefault(); focusNext(idx); }
      });
      inp.addEventListener('paste', function(e) {
        e.preventDefault();
        const paste = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '').slice(0, 6);
        paste.split('').forEach((ch, i) => {
          if (i < 6) { inputs[i].value = ch; inputs[i].className = 'digit-box filled'; }
        });
        if (paste.length > 0) inputs[Math.min(paste.length, 5)].focus();
        updateVerifyBtn();
      });
    });

    // Copy secret
    const copyBtn = document.getElementById('copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', async function() {
        try {
          await navigator.clipboard.writeText(secret);
          this.textContent = 'Copied!';
          setTimeout(() => { this.textContent = 'Copy'; }, 2000);
        } catch (_) { /* no-op */ }
      });
    }

    // Verify & enable
    verifyBtn.addEventListener('click', async function() {
      const code = getCode();
      if (code.length !== 6) return;
      verifyErr.style.display = 'none';
      this.disabled = true;
      this.innerHTML = '<span class="spinner"></span>Verifying…';

      const csrf = typeof window.__ZB_CSRF__ === 'string' && window.__ZB_CSRF__
        ? window.__ZB_CSRF__
        : (() => { try { return sessionStorage.getItem('zb-csrf') || ''; } catch(_) { return ''; } })();

      const res = await fetch('/api/staff/totp/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
        body: JSON.stringify({ code, secret })
      });

      if (res.ok) {
        // Show success and reload
        const toast = document.createElement('div');
        toast.className = 'success-toast';
        toast.textContent = '2FA enabled successfully!';
        document.body.appendChild(toast);
        setTimeout(() => { window.location.reload(); }, 1200);
        return;
      }

      const body = await res.json().catch(() => ({}));
      this.disabled = false;
      this.textContent = 'Verify & Enable';
      verifyErr.textContent = body.code === 'INVALID_CODE' ? 'Invalid code. Try again.' : (body.error || 'Verification failed');
      verifyErr.style.display = 'block';
      verifyGrid.classList.add('shake');
      setTimeout(() => verifyGrid.classList.remove('shake'), 300);
      inputs.forEach(inp => { inp.value = ''; inp.className = 'digit-box'; });
      inputs[0].focus();
    });

    // Disable 2FA
    const disableBtn = document.getElementById('disable-btn');
    if (disableBtn) {
      disableBtn.addEventListener('click', async function() {
        if (!confirm('Disable two-factor authentication? Your account will be less secure.')) return;
        const csrf = typeof window.__ZB_CSRF__ === 'string' && window.__ZB_CSRF__
          ? window.__ZB_CSRF__
          : (() => { try { return sessionStorage.getItem('zb-csrf') || ''; } catch(_) { return ''; } })();
        const res = await fetch('/api/staff/totp/disable', { method: 'POST', headers: { 'X-CSRF-Token': csrf } });
        if (res.ok) { window.location.reload(); }
        else { const b = await res.json().catch(()=>({})); alert(b.error || 'Failed to disable 2FA'); }
      });
    }

    updateVerifyBtn();
  })();
</script>