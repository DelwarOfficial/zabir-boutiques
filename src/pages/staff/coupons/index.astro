---
export const prerender = false;
import StaffLayout from "@/layouts/StaffLayout.astro";
import { getCurrentStaffUser, isOwnerTier } from "../../../lib/rbac";
import { getEnv } from "../../../lib/env";

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect("/staff/login");
if (!isOwnerTier(user.role)) return new Response("Forbidden", { status: 403 });

const env = getEnv(Astro);
const coupons = await env.DB.prepare(
  `SELECT c.*, s.full_name as created_by_name
   FROM coupons c
   LEFT JOIN staff_users s ON s.id = c.created_by
   ORDER BY c.created_at DESC`
).all<any>();
---

<StaffLayout title="Coupons" user={user}>
  <div class="flex justify-between items-center mb-6">
    <h1 class="m-0 text-xl font-bold">Coupon Management</h1>
    <span class="text-sm text-muted">{coupons.results?.length || 0} coupons</span>
  </div>

  <div class="overflow-x-auto border border-line rounded-lg">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="bg-surface-soft text-left">
          <th class="px-3 py-2.5 font-semibold">Code</th>
          <th class="px-3 py-2.5 font-semibold">Type</th>
          <th class="px-3 py-2.5 font-semibold">Discount</th>
          <th class="px-3 py-2.5 font-semibold">Min Order</th>
          <th class="px-3 py-2.5 font-semibold">Used</th>
          <th class="px-3 py-2.5 font-semibold">Limit</th>
          <th class="px-3 py-2.5 font-semibold">Expires</th>
          <th class="px-3 py-2.5 font-semibold">Active</th>
          <th class="px-3 py-2.5 font-semibold">Created By</th>
        </tr>
      </thead>
      <tbody>
        {coupons.results?.length ? coupons.results.map(c => <tr class="border-t border-line-soft">
          <td class="px-3 py-2 font-mono font-bold">{c.code}</td>
          <td class="px-3 py-2">{c.discount_type}</td>
          <td class="px-3 py-2 font-semibold">{c.discount_type === 'percentage' ? `${c.discount_percent}%${c.max_discount_paisa ? ` (max ৳${(c.max_discount_paisa/100).toFixed(0)})` : ''}` : `৳${(c.discount_amount_paisa/100).toFixed(2)}`}</td>
          <td class="px-3 py-2">{c.min_order_paisa ? `৳${(c.min_order_paisa/100).toFixed(2)}` : '—'}</td>
          <td class="px-3 py-2 text-center">{c.used_count}</td>
          <td class="px-3 py-2 text-center">{c.usage_limit ?? '∞'}</td>
          <td class="px-3 py-2 text-muted">{c.expires_at ? c.expires_at.split(' ')[0] : '—'}</td>
          <td class="px-3 py-2"><span class={`inline-block px-1.5 py-0.5 rounded text-[10px] ${c.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>{c.is_active ? 'Yes' : 'No'}</span></td>
          <td class="px-3 py-2 text-muted">{c.created_by_name || '—'}</td>
        </tr>) : <tr><td colspan="9" class="px-4 py-8 text-center text-muted">No coupons found.</td></tr>}
      </tbody>
    </table>
  </div>
</StaffLayout>