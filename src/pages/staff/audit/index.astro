---
import StaffLayout from "@/layouts/StaffLayout.astro";
import PageHeader from "@/components/staff/PageHeader.astro";
import { getCurrentStaffUser, can } from "../../../lib/rbac";
import { getEnv } from "../../../lib/env";
import { readCsrfCookie } from "../../../lib/csrf";
import type { AuditEntryWithActor } from "../../../types/audit";
import AuditLogViewer from "../../../islands/staff/AuditLogViewer.tsx";

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect("/staff/login");
if (!can(user.role, "system.audit.view")) return new Response("Forbidden", { status: 403 });

const env = getEnv(Astro);

// Fetch initial entries server-side for fast first paint
const page = 1;
const limit = 50;

const countRow = await env.DB.prepare(
  `SELECT COUNT(*) as total FROM audit_log`
).first<{ total: number }>();
const total = countRow?.total ?? 0;
const totalPages = Math.max(1, Math.ceil(total / limit));

const logs = await env.DB.prepare(
  `SELECT al.id, al.actor_staff_id, al.actor_role, al.action, al.entity_type,
          al.entity_id, al.metadata_json, al.ip_address, al.created_at,
          al.previous_hash, al.chain_hash,
          s.full_name as actor_name
   FROM audit_log al
   LEFT JOIN staff_users s ON s.id = al.actor_staff_id
   ORDER BY al.created_at DESC, al.rowid DESC
   LIMIT ? OFFSET ?`
).bind(limit, 0).all<any>();

const initialEntries: AuditEntryWithActor[] = (logs.results ?? []).map(r => ({
  ...r,
  previous_hash: r.previous_hash ?? '',
  chain_hash: r.chain_hash ?? '',
}));
---

<StaffLayout title="Audit Logs" user={user}>
  <PageHeader title="Audit Logs" subtitle="Tamper-proof activity ledger with hash-chain verification" />

  <div class="bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 text-xs text-amber-800 mb-4 flex items-center gap-2">
    <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2l8 4v6c0 5-3.5 9.4-8 10-4.5-.6-8-5-8-10V6z"/></svg>
    <span>All entries are append-only and protected by SHA-256 hash chain. No edits, no deletions.</span>
  </div>

  <AuditLogViewer
    client:load
    initialEntries={initialEntries}
    total={total}
    page={page}
    totalPages={totalPages}
    csrfToken={readCsrfCookie(Astro.request) ?? ''}
  />
</StaffLayout>
