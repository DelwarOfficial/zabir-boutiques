---
export const prerender = false;
import StaffLayout from "@/layouts/StaffLayout.astro";
import StepUpRequired from "@/components/staff/StepUpRequired.astro";
import PageHeader from "@/components/staff/PageHeader.astro";
import { getCurrentStaffUser, can } from "../../../lib/rbac";
import { getEnv } from "../../../lib/env";
import { requireRecentStaffSession, CriticalAuthError } from "../../../lib/critical-auth";

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect("/staff/login");
if (!can(user.role, "staff.manage")) return new Response("Forbidden", { status: 403 });
let needsStepUp = false;
try {
  await requireRecentStaffSession(Astro, user);
} catch (err) {
  if (err instanceof CriticalAuthError && err.code === 'STEP_UP_REQUIRED') {
    needsStepUp = true;
  } else if (err instanceof CriticalAuthError) {
    return err.toResponse();
  } else {
    throw err;
  }
}

const env = getEnv(Astro);
let staffList: any[] = [];
if (!needsStepUp) {
  const result = await env.DB.prepare(
    `SELECT id, email, phone, full_name, role, is_active, last_login_at, created_at
     FROM staff_users ORDER BY created_at DESC LIMIT 200`
  ).all<any>();
  staffList = result.results ?? [];
}
---
<StaffLayout title="Staff Users" user={user}>
  {needsStepUp ? (
    <StepUpRequired message="Staff user management requires recent authentication." />
  ) : (
  <Fragment>
  <PageHeader title="Staff Users" subtitle={`${staffList.length} users`} />
  <div class="overflow-x-auto border border-line rounded-lg">
    <table class="w-full border-collapse text-sm">
      <thead><tr class="bg-surface-soft text-left">
        <th class="px-3 py-2.5">Name</th>
        <th class="px-3 py-2.5">Email</th>
        <th class="px-3 py-2.5">Phone</th>
        <th class="px-3 py-2.5">Role</th>
        <th class="px-3 py-2.5">Active</th>
        <th class="px-3 py-2.5">Last Login</th>
      </tr></thead>
      <tbody>{staffList.map(s => <tr class="border-t border-line-soft">
        <td class="px-3 py-2 font-semibold">{s.full_name}</td>
        <td class="px-3 py-2">{s.email || "—"}</td>
        <td class="px-3 py-2">{s.phone || "—"}</td>
        <td class="px-3 py-2"><span class={`inline-block px-1.5 py-0.5 rounded text-[10px] ${['super_admin','owner'].includes(s.role) ? 'bg-amber-100 text-amber-800' : 'bg-sky-100 text-sky-800'}`}>{s.role}</span></td>
        <td class="px-3 py-2"><span class={`inline-block px-1.5 py-0.5 rounded text-[10px] ${s.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>{s.is_active ? 'Active' : 'Inactive'}</span></td>
        <td class="px-3 py-2 text-muted text-xs">{s.last_login_at || "Never"}</td>
      </tr>)}</tbody>
    </table>
  </div>
  </Fragment>
  )}
</StaffLayout>
