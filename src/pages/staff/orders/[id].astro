---
import StaffLayout from "@/layouts/StaffLayout.astro";
import { getCurrentStaffUser, can } from "../../../lib/rbac";
import { getEnv } from "../../../lib/env";
import { writeAuditLog } from "../../../lib/audit";

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect("/staff/login");
if (!can(user.role, "orders.view")) return new Response("Forbidden", { status: 403 });

const env = getEnv(Astro);
const { id } = Astro.params;

// PII access audit logging [Master_Prompt v7.0 §18.2]
await writeAuditLog(env.DB, {
  actorStaffId: user.id,
  actorRole: user.role,
  action: 'customer.pii.viewed',
  entityType: 'order',
  entityId: id ?? 'unknown',
  ipAddress: Astro.clientAddress ?? null,
  userAgent: Astro.request.headers.get('user-agent') ?? null,
}).catch(() => {});

const order = await env.DB.prepare(
  `SELECT o.*, s.full_name as created_by_name
   FROM orders o
   LEFT JOIN staff_users s ON s.id = o.created_by
   WHERE o.id = ?`
).bind(id).first<any>();

if (!order) return new Response("Order not found", { status: 404 });

const items = await env.DB.prepare(
  `SELECT oi.product_name, oi.variant_label, oi.quantity, oi.unit_price_paisa, oi.total_price_paisa
   FROM order_items oi
   WHERE oi.order_id = ?
   ORDER BY oi.created_at`
).bind(id).all<any>();

const payments = await env.DB.prepare(
  `SELECT * FROM payments WHERE order_id = ? ORDER BY created_at DESC`
).bind(id).all<any>();

const history = await env.DB.prepare(
  `SELECT h.*, s.full_name as changed_by_name
   FROM order_status_history h
   LEFT JOIN staff_users s ON s.id = h.changed_by
   WHERE h.order_id = ?
   ORDER BY h.created_at DESC`
).bind(id).all<any>();

const userCanConfirm = can(user.role, "orders.confirm");
const userCanPack = can(user.role, "orders.pack");
const userCanShip = can(user.role, "orders.ship");

function paisa(n: number): string { return `৳${(n / 100).toFixed(2)}`; }

const statusColors: Record<string, string> = {
  pending_review: "#f59e0b", pending_payment: "#f59e0b", payment_verified: "#3b82f6",
  paid_over_allocated: "#8b5cf6", staff_confirmed: "#06b6d4", packing: "#06b6d4",
  shipped: "#6366f1", delivered: "#22c55e", cancelled: "#ef4444", refunded: "#64748b",
};
---

<StaffLayout title={`Order ${order.order_number}`} user={user}>
  <div class="flex justify-between items-center mb-6">
    <div>
      <a href="/staff/orders" class="text-muted text-xs no-underline hover:underline">&larr; Orders</a>
      <h1 class="mt-1 text-xl font-bold m-0">{order.order_number}</h1>
    </div>
    <span style={`padding:0.35rem 0.75rem;border-radius:6px;font-size:0.8rem;font-weight:600;background:${(statusColors[order.status] || '#f1f5f9')}22;color:${statusColors[order.status] || '#475569'};`}>{order.status.replace(/_/g, " ")}</span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div class="bg-surface border border-line rounded-lg p-4">
      <h2 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Customer</h2>
      <div class="text-sm"><strong>{order.name}</strong></div>
      <div class="text-ink-secondary text-sm">{order.phone}</div>
      <div class="text-ink-secondary text-sm mt-1">{order.address}</div>
      {order.note && <div class="mt-2 p-2 bg-brand-light rounded text-sm">{order.note}</div>}
    </div>
    <div class="bg-surface border border-line rounded-lg p-4">
      <h2 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Payment & Order Info</h2>
      <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
        <span class="text-muted">Method</span><span>{order.payment_method}</span>
        <span class="text-muted">Payment</span><span class={`font-semibold ${['paid','partially_paid'].includes(order.payment_status) ? 'text-success' : order.payment_status === 'failed' ? 'text-danger' : 'text-ink'}`}>{order.payment_status}</span>
        <span class="text-muted">Channel</span><span>{order.order_channel}</span>
        <span class="text-muted">Fraud</span><span class={`font-semibold ${order.fraud_decision === 'approved' ? 'text-success' : order.fraud_decision === 'blocked' ? 'text-danger' : 'text-amber-600'}`}>{order.fraud_decision}</span>
        <span class="text-muted">Created</span><span>{order.created_at}</span>
        <span class="text-muted">By</span><span>{order.created_by_name || "Guest"}</span>
      </div>
    </div>
  </div>

  <div class="bg-surface border border-line rounded-lg p-4 mb-6">
    <h2 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Items</h2>
    <table class="w-full border-collapse text-sm">
      <thead><tr class="border-b border-line text-left">
        <th class="py-2 px-3 font-semibold">Product</th>
        <th class="py-2 px-3 font-semibold">Variant</th>
        <th class="py-2 px-3 font-semibold">Qty</th>
        <th class="py-2 px-3 font-semibold">Price</th>
        <th class="py-2 px-3 font-semibold">Total</th>
      </tr></thead>
      <tbody>
        {items.results?.map(i => (
          <tr class="border-b border-line-soft">
            <td class="py-2 px-3">{i.product_name}</td>
            <td class="py-2 px-3 text-muted">{i.variant_label}</td>
            <td class="py-2 px-3">{i.quantity}</td>
            <td class="py-2 px-3">{paisa(i.unit_price_paisa)}</td>
            <td class="py-2 px-3 font-semibold">{paisa(i.total_price_paisa)}</td>
          </tr>
        ))}
      </tbody>
      <tfoot>
        <tr><td colspan="4" class="py-2 px-3 text-right text-muted">Subtotal</td><td class="py-2 px-3">{paisa(order.subtotal_paisa)}</td></tr>
        {order.delivery_paisa > 0 && <tr><td colspan="4" class="py-2 px-3 text-right text-muted">Delivery</td><td class="py-2 px-3">{paisa(order.delivery_paisa)}</td></tr>}
        {order.discount_paisa > 0 && <tr><td colspan="4" class="py-2 px-3 text-right text-muted">Discount</td><td class="py-2 px-3 text-success">-{paisa(order.discount_paisa)}</td></tr>}
        {order.advance_paisa > 0 && <tr><td colspan="4" class="py-2 px-3 text-right text-muted">Advance Paid</td><td class="py-2 px-3 text-success">-{paisa(order.advance_paisa)}</td></tr>}
        <tr class="font-bold border-t-2 border-ink"><td colspan="4" class="py-2 px-3 text-right">Total</td><td class="py-2 px-3">{paisa(order.total_paisa)}</td></tr>
        {order.balance_paisa > 0 && <tr><td colspan="4" class="py-2 px-3 text-right text-muted">Balance Due</td><td class="py-2 px-3 text-danger font-semibold">{paisa(order.balance_paisa)}</td></tr>}
      </tfoot>
    </table>
  </div>

  {payments.results?.length > 0 && (
    <div class="bg-surface border border-line rounded-lg p-4 mb-6">
      <h2 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Payments</h2>
      <table class="w-full border-collapse text-sm">
        <thead><tr class="border-b border-line text-left">
          <th class="py-2 px-3">Invoice</th>
          <th class="py-2 px-3">Amount</th>
          <th class="py-2 px-3">Status</th>
          <th class="py-2 px-3">Date</th>
        </tr></thead>
        <tbody>{payments.results.map(p => <tr class="border-b border-line-soft">
          <td class="py-2 px-3">{p.invoice_id || "—"}</td>
          <td class="py-2 px-3">{paisa(p.amount_paisa)}</td>
          <td class="py-2 px-3"><span class={`inline-block px-1.5 py-0.5 rounded text-[10px] ${p.status === 'paid' ? 'bg-green-100 text-green-800' : p.status === 'failed' ? 'bg-red-100 text-red-800' : 'bg-amber-100 text-amber-800'}`}>{p.status}</span></td>
          <td class="py-2 px-3 text-muted text-xs">{p.created_at}</td>
        </tr>)}</tbody>
      </table>
    </div>
  )}

  <div class="flex gap-2 mb-6 flex-wrap">
    {userCanConfirm && ['pending_review', 'payment_verified'].includes(order.status) && (
      <button type="button" class="px-4 py-2 bg-cyan-600 text-white border-0 rounded cursor-pointer font-semibold text-sm order-action-btn" data-action="confirm" data-order-id={order.id}>
        {order.status === 'pending_review' ? 'Approve & Confirm' : 'Confirm Order'}
      </button>
    )}
    {userCanPack && order.status === "staff_confirmed" && (
      <button type="button" class="px-4 py-2 bg-cyan-600 text-white border-0 rounded cursor-pointer font-semibold text-sm order-action-btn" data-action="pack" data-order-id={order.id}>Mark Packing</button>
    )}
    {userCanShip && order.status === "packing" && (
      <button type="button" class="px-4 py-2 bg-indigo-600 text-white border-0 rounded cursor-pointer font-semibold text-sm order-action-btn" data-action="ship" data-order-id={order.id}>Mark Shipped</button>
    )}
    {order.fraud_decision === 'blocked' && (
      <span class="px-3 py-2 bg-red-100 text-red-800 rounded text-xs font-semibold">⚠️ FraudBD Blocked — requires override to confirm</span>
    )}
    {order.order_channel === 'in_store' && order.payment_method === 'in_store' && (
      <a href={`/api/staff/orders/${order.id}/invoice`} target="_blank" class="px-4 py-2 bg-brand text-white border border-brand rounded cursor-pointer font-semibold text-sm no-underline inline-flex items-center">Print POS Invoice</a>
    )}
    <a href={`/api/staff/orders/${order.id}/label`} target="_blank" class="px-4 py-2 bg-surface text-ink-secondary border border-line rounded cursor-pointer font-semibold text-sm no-underline inline-flex items-center">Print Label</a>
  </div>

<script is:inline>
  (function() {
    function getCsrf() {
      if (typeof window.__ZB_CSRF__ === 'string' && window.__ZB_CSRF__) return window.__ZB_CSRF__;
      try { return sessionStorage.getItem('zb-csrf') || ''; } catch (_) { return ''; }
    }
    document.querySelectorAll('.order-action-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const action = btn.dataset.action;
        const orderId = btn.dataset.orderId;
        if (!confirm(`Are you sure you want to ${action} this order?`)) return;
        btn.disabled = true; btn.textContent = 'Processing…';
        try {
          const res = await fetch(`/api/staff/orders/${orderId}/${action}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrf() }
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.ok) {
            window.location.reload();
          } else {
            alert(data.error || data.message || `Failed to ${action} order.`);
            btn.disabled = false; btn.textContent = btn.textContent;
          }
        } catch {
          alert('Network error.');
          btn.disabled = false;
        }
      });
    });
  })();
</script>

  <div class="bg-surface border border-line rounded-lg p-4">
    <h2 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Status History</h2>
    {history.results?.length ? <table class="w-full border-collapse text-sm">
      <thead><tr class="border-b border-line text-left">
        <th class="py-2 px-3">From</th>
        <th class="py-2 px-3">To</th>
        <th class="py-2 px-3">Changed By</th>
        <th class="py-2 px-3">Note</th>
        <th class="py-2 px-3">Date</th>
      </tr></thead>
      <tbody>{history.results.map(h => <tr class="border-b border-line-soft">
        <td class="py-2 px-3">{h.from_status || "—"}</td>
        <td class="py-2 px-3 font-semibold">{h.to_status}</td>
        <td class="py-2 px-3">{h.changed_by_name || "System"}</td>
        <td class="py-2 px-3 text-muted">{h.note || "—"}</td>
        <td class="py-2 px-3 text-muted text-xs">{h.created_at}</td>
      </tr>)}</tbody>
    </table> : <p class="text-muted text-sm">No status history recorded.</p>}
  </div>
</StaffLayout>
