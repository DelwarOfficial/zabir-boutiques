---
import StaffLayout from "@/layouts/StaffLayout.astro";
import PageHeader from "@/components/staff/PageHeader.astro";
import Table from "@/components/staff/ui/Table.astro";
import Badge from "@/components/staff/ui/Badge.astro";
import Pagination from "@/components/staff/ui/Pagination.astro";
import EmptyState from "@/components/staff/ui/EmptyState.astro";
import { getCurrentStaffUser, can } from "../../../lib/rbac";
import { getEnv } from "../../../lib/env";

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect("/staff/login");
if (!can(user.role, "orders.view")) return new Response("Forbidden", { status: 403 });

const env = getEnv(Astro);
const { searchParams } = new URL(Astro.request.url);
const statusFilter = searchParams.get("status") || "";
const page = Math.max(1, parseInt(searchParams.get("page") || "1", 10));
const limit = 25;
const offset = (page - 1) * limit;

let where = "WHERE 1=1";
const bindings: unknown[] = [];
if (statusFilter) {
  where += " AND o.status = ?";
  bindings.push(statusFilter);
}

const countRow = await env.DB.prepare(`SELECT COUNT(*) as total FROM orders o ${where}`).bind(...bindings).first<{ total: number }>();
const totalOrders = countRow?.total ?? 0;
const totalPages = Math.max(1, Math.ceil(totalOrders / limit));

const orders = await env.DB.prepare(
  `SELECT o.id, o.order_number, o.name, o.phone, o.total_paisa, o.payment_method, o.payment_status, o.status, o.fraud_decision, o.order_channel, o.created_at,
          s.full_name as created_by_name
   FROM orders o
   LEFT JOIN staff_users s ON s.id = o.created_by
   ${where}
   ORDER BY o.created_at DESC
   LIMIT ? OFFSET ?`
).bind(...bindings, limit, offset).all<{
  id: string; order_number: string; name: string; phone: string; total_paisa: number;
  payment_method: string; payment_status: string; status: string; fraud_decision: string;
  order_channel: string; created_at: string; created_by_name: string | null;
}>();

const statuses = ["pending_review", "pending_payment", "payment_verified", "paid_over_allocated", "staff_confirmed", "packing", "shipped", "delivered", "cancelled", "refunded"];

const statusBadge: Record<string, string> = {
  pending_review: 'bg-amber-100 text-amber-700', pending_payment: 'bg-amber-100 text-amber-700',
  payment_verified: 'bg-blue-100 text-blue-700', paid_over_allocated: 'bg-purple-100 text-purple-700',
  staff_confirmed: 'bg-cyan-100 text-cyan-700', packing: 'bg-cyan-100 text-cyan-700',
  shipped: 'bg-indigo-100 text-indigo-700', delivered: 'bg-green-100 text-green-700',
  cancelled: 'bg-red-100 text-red-700', refunded: 'bg-slate-100 text-slate-700',
};

const fraudBadge: Record<string, string> = {
  approved: 'bg-green-100 text-green-700', blocked: 'bg-red-100 text-red-700',
  review: 'bg-amber-100 text-amber-700',
};

const paymentBadge: Record<string, { variant: 'success' | 'danger' | 'warning'; label: string }> = {
  paid: { variant: 'success', label: 'Paid' },
  partially_paid: { variant: 'warning', label: 'Partial' },
  failed: { variant: 'danger', label: 'Failed' },
};

const columns = [
  { key: 'order_number', label: 'Order' },
  { key: 'customer', label: 'Customer' },
  { key: 'total', label: 'Total', align: 'right' as const },
  { key: 'payment', label: 'Payment' },
  { key: 'status', label: 'Status' },
  { key: 'channel', label: 'Channel' },
  { key: 'fraud', label: 'Fraud' },
  { key: 'created', label: 'Created' },
  { key: 'by', label: 'By' },
];

const filterQuery = statusFilter ? `?status=${statusFilter}` : '';
---

<StaffLayout title="Orders" user={user}>
  <PageHeader title="Orders" subtitle={`${totalOrders} total · Page ${page}/${totalPages}`} />

  <div class="mb-4 flex gap-2 flex-wrap">
    <a href="/staff/orders" class={`px-3 py-1.5 rounded-md text-xs no-underline ${!statusFilter ? 'bg-brand text-white' : 'bg-surface text-ink-secondary border border-line'}`}>All</a>
    {statuses.map(s => (
      <a href={`/staff/orders?status=${s}`} class={`px-3 py-1.5 rounded-md text-xs no-underline ${statusFilter === s ? 'bg-brand text-white' : 'bg-surface text-ink-secondary border border-line'}`}>
        {s.replace(/_/g, " ")}
      </a>
    ))}
  </div>

  <Table columns={columns} empty={!orders.results?.length} emptyMessage="No orders found matching your filters.">
    {orders.results?.length ? orders.results.map(o => (
      <tr class="border-t border-line-soft hover:bg-surface-soft transition-colors">
        <td class="px-3 py-2.5"><a href={`/staff/orders/${o.id}`} class="text-brand font-semibold no-underline">{o.order_number}</a></td>
        <td class="px-3 py-2.5">
          <div>{o.name}</div>
          <div class="text-muted text-xs">{o.phone}</div>
        </td>
        <td class="px-3 py-2.5 font-semibold">৳{(o.total_paisa / 100).toFixed(2)}</td>
        <td class="px-3 py-2.5">
          <Badge variant={paymentBadge[o.payment_status]?.variant ?? 'warning'}>{paymentBadge[o.payment_status]?.label ?? o.payment_status}</Badge>
        </td>
        <td class="px-3 py-2.5">
          <span class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-semibold ${statusBadge[o.status] || 'bg-surface-soft text-ink-secondary'}`}>{o.status.replace(/_/g, " ")}</span>
        </td>
        <td class="px-3 py-2.5 text-muted text-xs">{o.order_channel}</td>
        <td class="px-3 py-2.5">
          <span class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-semibold ${fraudBadge[o.fraud_decision] || 'bg-amber-100 text-amber-700'}`}>{o.fraud_decision}</span>
        </td>
        <td class="px-3 py-2.5 text-muted text-xs">{o.created_at?.split(" ")[0]}</td>
        <td class="px-3 py-2.5 text-muted text-xs">{o.created_by_name || "—"}</td>
      </tr>
    )) : (
      <tr><td colspan="9"><EmptyState icon="search" title="No orders found" description={statusFilter ? `No orders with status "${statusFilter.replace(/_/g, ' ')}"` : "No orders have been placed yet."} /></td></tr>
    )}
  </Table>

  {totalPages > 1 && (
    <Pagination current={page} total={totalPages} baseUrl={`/staff/orders${filterQuery}`} />
  )}
</StaffLayout>
