---
import "@/styles/global.css";
import { env } from "cloudflare:workers";

const TURNSTILE_SITE_KEY: string | undefined = env.TURNSTILE_SITE_KEY;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content="#faf9f7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1816" media="(prefers-color-scheme: dark)" />
    <title>Forgot Password — Zabir Boutiques</title>
    {TURNSTILE_SITE_KEY ? (
      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer nonce={Astro.locals.cspNonce}></script>
    ) : null}
    <style is:global>
      :root {
        --bg: #f5f4f0; --surface: #fff; --line: #e6e3dd; --ink: #1a1816;
        --ink-secondary: #6b6560; --muted: #9c9490; --brand: #b8860b; --brand-hover: #a0750a;
        --success: #16a34a; --error: #dc2626;
      }
      [data-theme="dark"] {
        --bg: #12100e; --surface: #1e1c1a; --line: #2d2926; --ink: #e8e4df;
        --ink-secondary: #9c9490; --muted: #6b6560; --brand: #d4a017; --brand-hover: #c4940e;
        --success: #22c55e; --error: #ef4444;
      }
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin:0; background:var(--bg); color:var(--ink);
        font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
        display:flex; align-items:center; justify-content:center;
        min-height:100vh; -webkit-font-smoothing: antialiased;
      }
      input:focus { border-color: var(--brand) !important; box-shadow: 0 0 0 3px rgba(184,134,11,0.15); }
      .brand-btn {
        width:100%; padding:0.65rem; background:var(--brand); color:#fff; border:none;
        border-radius:8px; font-size:0.9rem; font-weight:600; cursor:pointer;
        transition:background 0.15s, transform 0.1s;
      }
      .brand-btn:hover:not(:disabled) { background:var(--brand-hover); }
      .brand-btn:active:not(:disabled) { transform:scale(0.98); }
      .brand-btn:disabled { opacity:0.5; cursor:not-allowed; }
      .spinner { display:inline-block; width:16px; height:16px; border:2px solid rgba(255,255,255,0.3);
        border-top-color:#fff; border-radius:50%; animation:spin 0.6s linear; vertical-align:middle; margin-right:6px; }
      @keyframes spin { to{transform:rotate(360deg)} }
      .msg { font-size:0.8rem; margin:0.75rem 0 0; text-align:center; display:none; }
      .msg.success { color:var(--success); }
      .msg.error { color:var(--error); }
      .back-link { font-size:0.75rem; color:var(--muted); text-decoration:none; display:inline-block; margin-top:0.75rem; }
      .back-link:hover { color:var(--ink-secondary); }
    </style>
    <script nonce={Astro.locals.cspNonce} is:inline>
      (function(){
        var t = localStorage.getItem('zb-theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) {
          document.documentElement.setAttribute('data-theme','dark');
        }
      })();
    </script>
  </head>
  <body>
    <main style="width:100%;max-width:380px;padding:2rem;">
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:2rem;box-shadow:0 4px 32px rgba(0,0,0,0.06);">

        <!-- Brand -->
        <div style="text-align:center;margin-bottom:1.5rem;">
          <div style="font-size:1.5rem;font-weight:800;color:var(--brand);letter-spacing:-0.5px;">Zabir Boutiques</div>
          <div style="color:var(--muted);font-size:0.8rem;margin-top:0.15rem;">Reset your password</div>
        </div>

        <!-- Form -->
        <form id="forgot-form" novalidate>
          <div style="margin-bottom:1rem;">
            <label style="display:block;font-size:0.8rem;color:var(--ink-secondary);margin-bottom:0.3rem;">Email address</label>
            <input name="identifier" type="email" autocomplete="email" required
              style="width:100%;padding:0.6rem 0.75rem;border:1px solid var(--line);border-radius:8px;background:var(--surface);color:var(--ink);font-size:0.9rem;outline:none;" />
          </div>
          <div style="margin-bottom:1rem;font-size:0.8rem;color:var(--ink-secondary);">
            Enter the email address associated with your staff account and we'll send you a reset link.
          </div>
          {TURNSTILE_SITE_KEY ? <div class="cf-turnstile mb-3 flex justify-center" data-sitekey={TURNSTILE_SITE_KEY}></div> : null}
          <button type="submit" id="submit-btn" class="brand-btn">Send reset link</button>
          <p id="msg" class="msg"></p>
        </form>

        <div style="text-align:center;">
          <a class="back-link" href="/staff/login">&larr; Back to sign in</a>
        </div>

      </div>
      <p style="text-align:center;color:var(--muted);font-size:0.75rem;margin-top:1.5rem;">Zabir Boutiques &copy; 2026</p>
    </main>

    <script nonce={Astro.locals.cspNonce} is:inline>
      (function(){
        const form = document.getElementById('forgot-form');
        const btn = document.getElementById('submit-btn');
        const msg = document.getElementById('msg');

        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          msg.style.display = 'none';
          msg.className = 'msg';
          btn.disabled = true;
          btn.innerHTML = '<span class="spinner"></span>Sending…';

          var turnstileToken = '';
          try {
            const turnstileInput = document.querySelector('[name="cf-turnstile-response"]');
            turnstileToken = turnstileInput && turnstileInput.value ? turnstileInput.value : turnstile.getResponse();
          } catch (_) {}

          const identifier = form.querySelector('[name="identifier"]').value.trim();

          const res = await fetch('/api/staff/forgot-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ identifier, turnstile: turnstileToken })
          });

          btn.disabled = false;
          btn.textContent = 'Send reset link';

          const body = await res.json().catch(() => ({}));

          if (res.ok) {
            msg.textContent = 'If an account exists, a reset link has been sent.';
            msg.className = 'msg success';
            msg.style.display = 'block';
            form.querySelector('[name="identifier"]').value = '';
          } else {
            msg.textContent = body.error || 'Something went wrong. Try again.';
            msg.className = 'msg error';
            msg.style.display = 'block';
            try { turnstile.reset(); } catch (_) {}
          }
        });
      })();
    </script>
  </body>
</html>
