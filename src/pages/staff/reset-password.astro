---
import "@/styles/global.css";
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content="#faf9f7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1816" media="(prefers-color-scheme: dark)" />
    <title>Reset Password — Zabir Boutiques</title>
    <style is:global>
      :root {
        --bg: #f5f4f0; --surface: #fff; --line: #e6e3dd; --ink: #1a1816;
        --ink-secondary: #6b6560; --muted: #9c9490; --brand: #b8860b; --brand-hover: #a0750a;
        --success: #16a34a; --error: #dc2626;
      }
      [data-theme="dark"] {
        --bg: #12100e; --surface: #1e1c1a; --line: #2d2926; --ink: #e8e4df;
        --ink-secondary: #9c9490; --muted: #6b6560; --brand: #d4a017; --brand-hover: #c4940e;
        --success: #22c55e; --error: #ef4444;
      }
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin:0; background:var(--bg); color:var(--ink);
        font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
        display:flex; align-items:center; justify-content:center;
        min-height:100vh; -webkit-font-smoothing: antialiased;
      }
      input:focus { border-color: var(--brand) !important; box-shadow: 0 0 0 3px rgba(184,134,11,0.15); }
      .brand-btn {
        width:100%; padding:0.65rem; background:var(--brand); color:#fff; border:none;
        border-radius:8px; font-size:0.9rem; font-weight:600; cursor:pointer;
        transition:background 0.15s, transform 0.1s;
      }
      .brand-btn:hover:not(:disabled) { background:var(--brand-hover); }
      .brand-btn:active:not(:disabled) { transform:scale(0.98); }
      .brand-btn:disabled { opacity:0.5; cursor:not-allowed; }
      .spinner { display:inline-block; width:16px; height:16px; border:2px solid rgba(255,255,255,0.3);
        border-top-color:#fff; border-radius:50%; animation:spin 0.6s linear; vertical-align:middle; margin-right:6px; }
      @keyframes spin { to{transform:rotate(360deg)} }
      .msg { font-size:0.8rem; margin:0.75rem 0 0; text-align:center; display:none; }
      .msg.success { color:var(--success); }
      .msg.error { color:var(--error); }
      .back-link { font-size:0.75rem; color:var(--muted); text-decoration:none; display:inline-block; margin-top:0.75rem; }
      .back-link:hover { color:var(--ink-secondary); }
      .requirements { font-size:0.75rem; color:var(--muted); margin:0.25rem 0 0.75rem; }
      .requirements li { margin-bottom:0.15rem; }
    </style>
    <script nonce={Astro.locals.cspNonce} is:inline>
      (function(){
        var t = localStorage.getItem('zb-theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) {
          document.documentElement.setAttribute('data-theme','dark');
        }
      })();
    </script>
  </head>
  <body>
    <main style="width:100%;max-width:380px;padding:2rem;">
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:2rem;box-shadow:0 4px 32px rgba(0,0,0,0.06);">

        <!-- Brand -->
        <div style="text-align:center;margin-bottom:1.5rem;">
          <div style="font-size:1.5rem;font-weight:800;color:var(--brand);letter-spacing:-0.5px;">Zabir Boutiques</div>
          <div style="color:var(--muted);font-size:0.8rem;margin-top:0.15rem;">Set new password</div>
        </div>

        <!-- Form state -->
        <div id="form-state">
          <form id="reset-form" novalidate>
            <div style="margin-bottom:0.75rem;">
              <label style="display:block;font-size:0.8rem;color:var(--ink-secondary);margin-bottom:0.3rem;">New password</label>
              <input name="password" type="password" autocomplete="new-password" required minlength="10"
                style="width:100%;padding:0.6rem 0.75rem;border:1px solid var(--line);border-radius:8px;background:var(--surface);color:var(--ink);font-size:0.9rem;outline:none;" />
            </div>
            <div style="margin-bottom:0.5rem;">
              <label style="display:block;font-size:0.8rem;color:var(--ink-secondary);margin-bottom:0.3rem;">Confirm password</label>
              <input name="confirm" type="password" autocomplete="new-password" required minlength="10"
                style="width:100%;padding:0.6rem 0.75rem;border:1px solid var(--line);border-radius:8px;background:var(--surface);color:var(--ink);font-size:0.9rem;outline:none;" />
            </div>
            <ul class="requirements">
              <li>At least 10 characters</li>
              <li>At least one uppercase letter</li>
              <li>At least one number</li>
              <li>At least one special character</li>
            </ul>
            <button type="submit" id="reset-btn" class="brand-btn">Set new password</button>
            <p id="reset-msg" class="msg"></p>
          </form>
        </div>

        <!-- Success state -->
        <div id="success-state" style="display:none;text-align:center;">
          <div style="font-size:2.5rem;margin-bottom:0.75rem;">&#10003;</div>
          <p style="font-size:0.9rem;color:var(--ink-secondary);margin:0 0 1rem;">Password reset successful!</p>
          <a href="/staff/login" class="brand-btn" style="display:inline-block;text-decoration:none;">Sign in</a>
        </div>

        <!-- Error state -->
        <div id="error-state" style="display:none;text-align:center;">
          <div style="font-size:2rem;margin-bottom:0.75rem;color:var(--error);">&#10007;</div>
          <p id="error-text" style="font-size:0.9rem;color:var(--ink-secondary);margin:0 0 1rem;">This reset link is invalid or has expired.</p>
          <a href="/staff/forgot-password" class="brand-btn" style="display:inline-block;text-decoration:none;">Request new link</a>
        </div>

      </div>
      <p style="text-align:center;color:var(--muted);font-size:0.75rem;margin-top:1.5rem;">Zabir Boutiques &copy; 2026</p>
    </main>

    <script nonce={Astro.locals.cspNonce} is:inline>
      (function(){
        const params = new URLSearchParams(window.location.search);
        const token = params.get('token');

        if (!token) {
          document.getElementById('form-state').style.display = 'none';
          document.getElementById('error-state').style.display = 'block';
          document.getElementById('error-text').textContent = 'No reset token found.';
          return;
        }

        const form = document.getElementById('reset-form');
        const btn = document.getElementById('reset-btn');
        const msg = document.getElementById('reset-msg');

        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          msg.style.display = 'none';
          msg.className = 'msg';
          btn.disabled = true;
          btn.innerHTML = '<span class="spinner"></span>Resetting…';

          const password = form.querySelector('[name="password"]').value;
          const confirm = form.querySelector('[name="confirm"]').value;

          if (password !== confirm) {
            btn.disabled = false;
            btn.textContent = 'Set new password';
            msg.textContent = 'Passwords do not match.';
            msg.className = 'msg error';
            msg.style.display = 'block';
            return;
          }

          const res = await fetch('/api/staff/reset-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token, password })
          });

          const body = await res.json().catch(() => ({}));

          if (res.ok) {
            document.getElementById('form-state').style.display = 'none';
            document.getElementById('success-state').style.display = 'block';
          } else {
            btn.disabled = false;
            btn.textContent = 'Set new password';
            if (res.status === 400) {
              // Bad token — show error state instead
              document.getElementById('form-state').style.display = 'none';
              document.getElementById('error-state').style.display = 'block';
              document.getElementById('error-text').textContent = body.error || 'This reset link is invalid or has expired.';
            } else {
              msg.textContent = body.error || 'Something went wrong. Try again.';
              msg.className = 'msg error';
              msg.style.display = 'block';
            }
          }
        });
      })();
    </script>
  </body>
</html>
