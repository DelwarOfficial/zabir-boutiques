---
import StaffLayout from '@/layouts/StaffLayout.astro';
import PageHeader from '@/components/staff/PageHeader.astro';
import { getCurrentStaffUser, can } from '../../../lib/rbac';
import MergedProductUpload from '../../../islands/staff/MergedProductUpload.tsx';

const user = await getCurrentStaffUser(Astro);
if (!user) return Astro.redirect('/staff/login');
if (!can(user.role, 'products.manage')) return new Response('Forbidden', { status: 403 });
---

<StaffLayout title="New Product" user={user}>
  <PageHeader title="New Product" subtitle="Create a new product with variants and inventory" />
  <MergedProductUpload client:load />
</StaffLayout>
