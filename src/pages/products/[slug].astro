---
import RootLayout from "@/layouts/RootLayout.astro";
import { AddToCartButton } from "@/islands/AddToCartButton";
import { CATALOG_PRODUCTS } from "@/data/catalog";
import { formatPaisa } from "@/lib/money";

export const prerender = true;

export function getStaticPaths() {
  return CATALOG_PRODUCTS.map((product) => ({ params: { slug: product.slug }, props: { product } }));
}

const { product } = Astro.props;
const lowStock = product.availableQuantity > 0 && product.availableQuantity <= 3;
const outOfStock = product.availableQuantity <= 0;
---

<RootLayout title={`${product.title} | Zabir Boutiques`} activeCategory={product.categorySlug}>
  <article class="grid gap-5 md:grid-cols-[0.9fr_1fr] fade-up">
    <div class="md:sticky md:top-32 self-start">
      <div class="relative aspect-[4/5] overflow-hidden rounded-3xl bg-[var(--surface-soft)] shadow-md shine-card">
        <img src={product.imageUrl} alt={product.title} width="512" height="640" class="h-full w-full object-cover" fetchpriority="high" />
        {lowStock && (
          <span class="absolute left-3 top-3 chip chip-danger pop">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--danger)]" aria-hidden="true"></span>
            Only {product.availableQuantity} left
          </span>
        )}
        {outOfStock && (
          <span class="absolute left-3 top-3 chip" style="background:rgba(0,0,0,0.7);color:#fff;border-color:transparent">Sold out</span>
        )}
      </div>
    </div>

    <div class="md:py-2">
      <nav class="text-[11px] uppercase tracking-[0.18em] font-bold text-[var(--muted)]">
        <a href="/" class="hover:text-[var(--brand)]">Home</a> <span class="mx-1">/</span>
        <a href={`/categories/${product.categorySlug}`} class="hover:text-[var(--brand)]">{product.categorySlug.replace(/-/g, " ")}</a>
      </nav>
      <h1 class="mt-2 text-2xl sm:text-3xl font-extrabold leading-tight tracking-tight">{product.title}</h1>
      <p class="mt-1 text-sm text-[var(--muted)]">{product.variantLabel}</p>
      <p class="mt-3 text-3xl font-extrabold text-[var(--ink)] tabular">{formatPaisa(product.pricePaisa)}</p>
      <p class={`mt-2 inline-flex items-center gap-1.5 text-xs font-bold ${outOfStock ? "text-[var(--danger)]" : lowStock ? "text-amber-600" : "text-[var(--success)]"}`}>
        <span class={`h-1.5 w-1.5 rounded-full ${outOfStock ? "bg-[var(--danger)]" : lowStock ? "bg-amber-500" : "bg-[var(--success)]"}`} aria-hidden="true"></span>
        {outOfStock ? "Out of stock" : lowStock ? `Only ${product.availableQuantity} in stock — order soon` : `${product.availableQuantity} in stock`}
      </p>

      <div class="mt-5 hidden md:block max-w-sm">
        <AddToCartButton
          client:idle
          productId={product.id}
          variantId={product.variantId}
          title={product.title}
          imageUrl={product.imageUrl}
          variantLabel={product.variantLabel}
          unitPricePaisa={product.pricePaisa}
          availableQuantity={product.availableQuantity}
          variant="sticky"
        />
      </div>

      <div class="mt-6 grid gap-3 text-sm leading-6 text-[var(--muted)] stagger">
        <p class="shell-card p-3 flex gap-2 items-start">
          <svg class="h-4 w-4 mt-0.5 text-[var(--brand)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
          Checkout reserves stock with a fresh D1 conditional update. Displayed stock is never trusted during checkout.
        </p>
        <p class="shell-card p-3 flex gap-2 items-start">
          <svg class="h-4 w-4 mt-0.5 text-[var(--brand)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 7h11v10H3z"/><path d="M14 10h4l3 3v4h-7z"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
          Inside Dhaka ৳70 · Outside Dhaka ৳130. COD default; UddoktaPay available.
        </p>
        <p class="shell-card p-3 flex gap-2 items-start">
          <svg class="h-4 w-4 mt-0.5 text-[var(--brand)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 01-8.5 8.5 8.5 8.5 0 01-7.6-4.7L3 21l1.7-1.9A8.38 8.38 0 0112 3a8.5 8.5 0 019 8.5z"/></svg>
          WhatsApp +880 1985-516000 for urgent delivery.
        </p>
      </div>
    </div>
  </article>

  <!-- Sticky mobile CTA bar (only on small screens, doesn't fight desktop layout) -->
  <div class="sticky-cta md:hidden">
    <div class="flex items-center gap-3">
      <div class="min-w-0 flex-1">
        <p class="line-clamp-1 text-[11px] font-semibold text-[var(--muted)]">{product.title}</p>
        <p class="text-base font-extrabold tabular">{formatPaisa(product.pricePaisa)}</p>
      </div>
      <div class="w-44">
        <AddToCartButton
          client:idle
          productId={product.id}
          variantId={product.variantId}
          title={product.title}
          imageUrl={product.imageUrl}
          variantLabel={product.variantLabel}
          unitPricePaisa={product.pricePaisa}
          availableQuantity={product.availableQuantity}
          variant="sticky"
        />
      </div>
    </div>
  </div>
</RootLayout>
