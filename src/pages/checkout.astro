---
import RootLayout from "@/layouts/RootLayout.astro";
import CheckoutSkeleton from "@/components/checkout/CheckoutSkeleton.astro";
import { GuestCheckout } from "@/islands/GuestCheckout";

const env = (Astro.locals as any).runtime?.env;
const turnstileSiteKey: string | undefined = env?.TURNSTILE_SITE_KEY;
---

<RootLayout title="Guest Checkout | Zabir Boutiques">
  <GuestCheckout client:load turnstileSiteKey={turnstileSiteKey}>
    <CheckoutSkeleton slot="fallback" />
  </GuestCheckout>
</RootLayout>
