---
import Header from "@/components/shell/Header.astro";
import CategoryRail from "@/components/shell/CategoryRail.astro";
import Footer from "@/components/shell/Footer.astro";
import { BottomNav } from "@/islands/BottomNav";
import "@/styles/global.css";

type Props = {
  title: string;
  description?: string;
  activeCategory?: string;
  ogImage?: string;
};

const { title, description = "Premium boutique fashion from Wari, Dhaka with COD-first checkout.", activeCategory = "", ogImage } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://zabirboutiques.com").href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Icons -->
    <link rel="icon" href="/assets/zabir-logo.jpg" />
    <link rel="apple-touch-icon" href="/assets/zabir-logo.jpg" />

    <!-- Theme: prevent flash by applying stored preference synchronously -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('zb-theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) {
          document.documentElement.setAttribute('data-theme','dark');
        }
      })();
    </script>
    <meta name="theme-color" content="#faf9f7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1816" media="(prefers-color-scheme: dark)" />

    <title>{title}</title>
  </head>
  <body class="font-sans antialiased">
    <div class="min-h-dvh pb-24 md:pb-0">
      <Header />
      <CategoryRail activeSlug={activeCategory} />
      <main class="mx-auto max-w-7xl px-4 md:px-8 lg:px-16 py-6 md:py-10">
        <slot />
      </main>
      <Footer />
    </div>
    <!-- Bottom nav: idle-hydrated (not blocking LCP) -->
    <BottomNav client:idle />
    <!-- Web Vitals RUM [Master_Prompt v7.0 §21] -->
    <script>
      import { initWebVitals } from '../lib/web-vitals';
      initWebVitals();
    </script>
  </body>
</html>
