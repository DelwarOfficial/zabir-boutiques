---
import Header from "@/components/shell/Header.astro";
import CategoryRail from "@/components/shell/CategoryRail.astro";
import Footer from "@/components/shell/Footer.astro";
import BottomNav from "@/components/shell/BottomNav.astro";
import { CartDrawer } from "@/islands/CartDrawer";
import { MobileMenu } from "@/islands/MobileMenu";
import Toast from "@/components/primitives/Toast.astro";
import { CATALOG_CATEGORIES } from "@/data/catalog";
import "@/styles/global.css";

type Props = {
  title: string;
  description?: string;
  activeCategory?: string;
  ogImage?: string;
};

const { title, description = "Premium boutique fashion from Wari, Dhaka with COD-first checkout.", activeCategory = "", ogImage } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://zabirboutiques.com").href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Zabir" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <!-- Icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />

    <!-- Theme: prevent flash by applying stored preference synchronously -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('zb-theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) {
          document.documentElement.setAttribute('data-theme','dark');
        }
      })();
    </script>
    <meta name="theme-color" content="#faf9f7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1816" media="(prefers-color-scheme: dark)" />

    <slot name="head" />

    <title>{title}</title>
  </head>
  <body class="font-sans antialiased bg-[var(--bg-storefront)] text-[var(--ink-storefront)]">
    <div class="min-h-dvh pb-24 md:pb-0">
      <Header />
      <CategoryRail activeSlug={activeCategory} />
      <main class="mx-auto max-w-7xl px-4 md:px-8 lg:px-16 py-6 md:py-10">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Global Client Islands -->
    <CartDrawer client:idle />
    <MobileMenu client:idle categories={CATALOG_CATEGORIES} />
    <Toast />

    <!-- Bottom nav (Static Astro Component) -->
    <BottomNav />

    <!-- PwaInstallHint (Native HTML/JS to avoid React hydration overhead) -->
    <div
      id="pwa-install-hint"
      class="hidden fixed inset-x-4 bottom-20 z-50 mx-auto max-w-md rounded-xl border border-[var(--line)] bg-[var(--surface)] p-4 shadow-lg md:bottom-6"
      role="region"
      aria-label="Install app"
    >
      <p class="text-sm font-semibold text-[var(--ink)]">Install Zabir Boutiques</p>
      <p class="mt-1 text-xs text-[var(--muted)]">
        Add to your home screen for faster access to our storefront.
      </p>
      <div class="mt-3 flex gap-2">
        <button
          id="pwa-install-btn"
          type="button"
          class="rounded-md bg-[var(--brand)] px-3 py-1.5 text-xs font-semibold text-white cursor-pointer"
        >
          Install
        </button>
        <button
          id="pwa-dismiss-btn"
          type="button"
          class="rounded-md border border-[var(--line)] px-3 py-1.5 text-xs text-[var(--ink-secondary)] cursor-pointer"
        >
          Not now
        </button>
      </div>
    </div>

    <script is:inline>
      (function() {
        const hint = document.getElementById('pwa-install-hint');
        const installBtn = document.getElementById('pwa-install-btn');
        const dismissBtn = document.getElementById('pwa-dismiss-btn');
        const DISMISS_KEY = 'zb-pwa-install-dismissed';

        if (!hint || !installBtn || !dismissBtn) return;
        if (window.matchMedia('(display-mode: standalone)').matches) return;
        if (localStorage.getItem(DISMISS_KEY) === '1') return;

        let deferredEvent = null;

        window.addEventListener('beforeinstallprompt', function(e) {
          e.preventDefault();
          deferredEvent = e;
          hint.classList.remove('hidden');
        });

        installBtn.addEventListener('click', async function() {
          if (!deferredEvent) return;
          await deferredEvent.prompt();
          await deferredEvent.userChoice;
          hint.classList.add('hidden');
          deferredEvent = null;
        });

        dismissBtn.addEventListener('click', function() {
          localStorage.setItem(DISMISS_KEY, '1');
          hint.classList.add('hidden');
          deferredEvent = null;
        });
      })();
    </script>

    <!-- Add to Cart helper for non-island cards -->
    <script is:inline>
      (function() {
        window.addItemToLocalCart = function(item) {
          if (item.availableQuantity <= 0) return;
          try {
            const raw = localStorage.getItem('zb_cart_v68a') || '[]';
            const cart = JSON.parse(raw);
            const existing = cart.find(function(i) { return i.variantId === item.variantId; });
            if (existing) {
              existing.quantity += item.quantity;
            } else {
              cart.push(item);
            }
            localStorage.setItem('zb_cart_v68a', JSON.stringify(cart));
            
            // Sync with server if session exists
            fetch('/api/cart', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ action: 'add', variantId: item.variantId, quantity: item.quantity })
            }).catch(function() {});
            
            window.dispatchEvent(new CustomEvent('zb-cart-updated'));
            window.dispatchEvent(new CustomEvent('zb-cart-open'));
            
            if (typeof window.showToast === 'function') {
              window.showToast("Added " + item.title + " to cart!", 'success');
            }
          } catch (err) {
            console.error(err);
          }
        };
      })();
    </script>

    <!-- Web Vitals RUM -->
    <script>
      import { initWebVitals } from '../lib/web-vitals';
      import { registerServiceWorker } from '../lib/pwa/register';
      initWebVitals();
      registerServiceWorker();
    </script>
  </body>
</html>
