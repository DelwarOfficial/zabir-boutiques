---
export const prerender = false;

import "@/styles/global.css";
import type { StaffUser } from "@/lib/rbac";
import { menuForRole } from "@/lib/staff-menu";

type Props = {
  title: string;
  user: StaffUser;
};

const { title, user } = Astro.props;
const currentPath = Astro.url.pathname;
const menu = menuForRole(user.role).map(item => ({
  ...item,
  active: item.href === currentPath || (item.href !== "/staff" && currentPath.startsWith(item.href)),
}));

const roleLabel: Record<string, string> = {
  super_admin: "Super Admin",
  owner: "Owner",
  manager: "Manager",
  salesman: "Sales Staff",
  packing: "Packing Staff",
  support: "Support",
};
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content="#faf9f7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1816" media="(prefers-color-scheme: dark)" />
    <title>{title} — Zabir Boutiques Staff</title>
    <script is:inline>
      (function(){
        var t = localStorage.getItem('zb-theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) {
          document.documentElement.setAttribute('data-theme','dark');
        }
      })();
    </script>
    <style is:inline>
      .staff-sidebar { width:220px;min-width:220px;background:var(--surface-soft);border-right:1px solid var(--line);padding:1rem 0;overflow-y:auto;transition:transform 0.2s; }
      .staff-sidebar a { display:block;padding:0.5rem 1.25rem;color:var(--ink-secondary);text-decoration:none;font-size:0.875rem;border-left:3px solid transparent;transition:background 0.15s,border-color 0.15s,color 0.15s; }
      .staff-sidebar a:hover { background:var(--brand-glow);color:var(--ink); }
      .staff-sidebar a.active { border-left-color:var(--brand);background:var(--brand-glow);font-weight:600;color:var(--ink); }
      .staff-toggle { display:none;background:none;border:none;cursor:pointer;padding:0.25rem;color:var(--ink-secondary); }
      @media (max-width:768px) {
        .staff-sidebar { position:fixed;top:57px;left:0;bottom:0;z-index:100;transform:translateX(-100%); }
        .staff-sidebar.open { transform:translateX(0);box-shadow:4px 0 20px rgba(0,0,0,0.1); }
        .staff-toggle { display:block; }
      }
    </style>
  </head>
  <body class="bg-bg text-ink font-sans m-0">
    <header class="flex justify-between items-center px-6 py-3 bg-surface border-b border-line">
      <div class="flex items-center gap-3">
        <button id="sidebar-toggle" class="staff-toggle md:hidden text-xl leading-none" type="button" aria-label="Toggle navigation">☰</button>
        <a href="/staff" class="text-brand text-[1.125rem] font-bold no-underline">Zabir Boutiques — Staff</a>
      </div>
      <div class="flex items-center gap-4 text-sm">
        <span>{user.fullName} · <span class="text-muted">{roleLabel[user.role] ?? user.role}</span></span>
        <button id="logout-btn" type="button" class="px-3 py-1.5 border border-line rounded-md bg-surface text-ink-secondary hover:bg-surface-soft text-sm cursor-pointer">Sign out</button>
      </div>
    </header>
    <div class="flex min-h-[calc(100vh-57px)]">
      <nav id="sidebar" class="staff-sidebar w-[220px] min-w-[220px] bg-surface-soft border-r border-line p-4 overflow-y-auto md:static md:translate-x-0" aria-label="Staff navigation">
        <ul class="list-none p-0 m-0">
          {menu.map((item) => (
            <li>
              <a 
                href={item.href} 
                class={`block px-5 py-2 text-sm text-ink-secondary no-underline border-l-3 transition-colors ${item.active 
                  ? 'border-brand bg-brand-glow font-semibold text-ink' 
                  : 'border-transparent hover:bg-surface hover:text-ink'}`}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <main class="flex-1 p-6 overflow-y-auto">
        <slot />
      </main>
    </div>
    <script is:inline>
      // Sidebar toggle (mobile)
      document.getElementById('sidebar-toggle')?.addEventListener('click', function() {
        document.getElementById('sidebar')?.classList.toggle('open');
      });
      // Close sidebar on nav click (mobile)
      document.getElementById('sidebar')?.addEventListener('click', function(e) {
        if (window.innerWidth <= 768 && e.target instanceof HTMLAnchorElement) {
          this.classList.remove('open');
        }
      });

      // Logout handler
      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        const m = document.cookie.match(/(?:^|;\s*)csrf-token=([^;]+)/);
        const csrf = m ? decodeURIComponent(m[1]) : '';
        await fetch('/api/staff/logout', {
          method: 'POST',
          headers: { 'X-CSRF-Token': csrf }
        });
        window.location.href = '/staff/login';
      });

      // CSRF enhancer for staff mutation forms
      function getCsrf() {
        const m = document.cookie.match(/(?:^|;\s*)csrf-token=([^;]+)/);
        return m ? decodeURIComponent(m[1]) : '';
      }
      document.addEventListener('submit', (e) => {
        const form = e.target;
        if (!(form instanceof HTMLFormElement)) return;
        const action = form.getAttribute('action') || '';
        if (form.method.toLowerCase() === 'post' && action.includes('/api/staff/')) {
          const csrf = getCsrf();
          if (csrf) {
            e.preventDefault();
            const data = new FormData(form);
            fetch(action, {
              method: 'POST',
              headers: { 'X-CSRF-Token': csrf },
              body: data
            }).then(res => {
              if (res.ok) { window.location.reload(); }
              else { res.json().then(b => alert(b.error || b.message || 'Action failed')).catch(() => alert('Action failed')); }
            }).catch(() => alert('Network error'));
          }
        }
      }, true);
    </script>
  </body>
</html>