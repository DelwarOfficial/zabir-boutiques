---
import { getSession } from "@/lib/auth/session";

interface Props {
  title?: string;
  sidebar?: boolean;
}

const { title, sidebar = true } = Astro.props;
const session = await getSession(Astro.request);

if (!session?.user?.id) {
  return Astro.redirect("/staff/login");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} - Staff` : "Staff Dashboard"}</title>
  </head>
  <body class="staff-shell bg-[var(--bg-storefront)] text-[var(--ink-storefront)]">
    <div class="flex h-screen flex-col md:flex-row">
      <!-- Sidebar (collapsible on mobile) -->
      {sidebar && (
        <aside class="hidden md:block w-64 bg-[var(--surface-storefront)] border-r border-[var(--border-storefront)] overflow-y-auto">
          <nav class="p-4 space-y-2">
            <a href="/staff" class="block px-4 py-2 rounded-lg hover:bg-[var(--surface-soft)] transition-colors text-sm font-medium">
              Dashboard
            </a>
            <a href="/staff/orders" class="block px-4 py-2 rounded-lg hover:bg-[var(--surface-soft)] transition-colors text-sm font-medium">
              Orders
            </a>
            <a href="/staff/pos" class="block px-4 py-2 rounded-lg hover:bg-[var(--surface-soft)] transition-colors text-sm font-medium">
              POS
            </a>
            <a href="/staff/coupons" class="block px-4 py-2 rounded-lg hover:bg-[var(--surface-soft)] transition-colors text-sm font-medium">
              Coupons
            </a>
            <a href="/staff/products" class="block px-4 py-2 rounded-lg hover:bg-[var(--surface-soft)] transition-colors text-sm font-medium">
              Products
            </a>
            <hr class="my-4 border-[var(--border-storefront)]" />
            <button onclick="fetch('/staff/logout', {method: 'POST'}).then(() => window.location.href='/')" class="w-full text-left px-4 py-2 rounded-lg hover:bg-[var(--danger-storefront)]/10 transition-colors text-sm font-medium text-[var(--danger-storefront)]">
              Logout
            </button>
          </nav>
        </aside>
      )}

      <!-- Main content -->
      <main class="flex-1 overflow-y-auto">
        <!-- Header -->
        <header class="sticky top-0 z-30 border-b border-[var(--border-storefront)] bg-[var(--surface-storefront)] px-4 sm:px-6 py-3 flex items-center justify-between">
          <h1 class="text-lg sm:text-xl font-bold">{title || "Staff Dashboard"}</h1>
          <div class="flex items-center gap-3">
            <span class="text-sm text-[var(--muted)]">{session.user.email}</span>
            <button onclick="fetch('/staff/logout', {method: 'POST'}).then(() => window.location.href='/')" class="text-xs px-3 py-1.5 rounded-lg border border-[var(--border-storefront)] hover:bg-[var(--surface-soft)] transition-colors">
              Logout
            </button>
          </div>
        </header>

        <!-- Content area -->
        <div class="p-4 sm:p-6">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
